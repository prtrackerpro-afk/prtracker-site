# Mercado Pago — obter em https://www.mercadopago.com.br/developers/panel
# Para produção, use credenciais "produtivo". Para testes, use "teste".
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Melhor Envio — personal token em https://melhorenvio.com.br/painel/gerenciar/tokens
# Escopos mínimos: cart-read, cart-write, orders-read, shipping-calculate,
# shipping-cancel, shipping-checkout, shipping-companies, shipping-generate,
# shipping-preview, shipping-print, shipping-tracking, users-read.
# Token expira em ~18 meses; renovar manualmente antes do vencimento.
ME_ACCESS_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiJ9.xxxxxxxx
ME_CEP_ORIGEM=90460080
# "true" usa sandbox.melhorenvio.com.br. "false" ou não definido usa produção.
ME_SANDBOX=false

# Site URL (usado em canonical, og:url, sitemap). Não precisa em dev.
PUBLIC_SITE_URL=https://prtracker.com.br
