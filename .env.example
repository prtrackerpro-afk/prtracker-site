# Mercado Pago — obter em https://www.mercadopago.com.br/developers/panel
# Para produção, use credenciais "produtivo". Para testes, use "teste".
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Melhor Envio — personal token em https://melhorenvio.com.br/painel/gerenciar/tokens
# Escopos mínimos: cart-read, cart-write, orders-read, shipping-calculate,
# shipping-cancel, shipping-checkout, shipping-companies, shipping-generate,
# shipping-preview, shipping-print, shipping-tracking, users-read.
# Token expira em ~18 meses; renovar manualmente antes do vencimento.
ME_ACCESS_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiJ9.xxxxxxxx
ME_CEP_ORIGEM=90460080
# "true" usa sandbox.melhorenvio.com.br. "false" ou não definido usa produção.
ME_SANDBOX=false

# Site URL (usado em canonical, og:url, sitemap). Não precisa em dev.
PUBLIC_SITE_URL=https://prtracker.com.br

# Meta Conversions API — gerado em Events Manager → Pixel PR Tracker →
# Configurações → API de Conversões → Configurar com Dataset Quality API.
# Usado pelo webhook MP para enviar Purchase server-side (dedup com Pixel via eventID).
META_CAPI_ACCESS_TOKEN=EAAxxxxxxxxxxxx
META_PIXEL_ID=1278981700843845

# GA4 Measurement Protocol — Admin → Data Streams → PR Tracker v2 →
# Measurement Protocol API secrets → Criar. Mesma finalidade do CAPI no GA4.
GA4_API_SECRET=xxxxxxxx
GA4_MEASUREMENT_ID=G-B2EPJXKSPZ

# Vercel — https://vercel.com/account/tokens. Usado pelo Claude Code para
# deploy de preview e leitura de logs do webhook em produção.
VERCEL_TOKEN=vercel_xxxxxxxx
VERCEL_PROJECT_ID=prj_xxxxxxxx
VERCEL_ORG_ID=team_xxxxxxxx

# =============================================================================
# Admin Dashboard (rota /admin)
# =============================================================================

# Supabase project — criar em https://supabase.com/dashboard/projects
# Após criar:
#   1. Project Settings → API → copiar URL + anon key + service_role key
#   2. SQL Editor → rodar supabase/migrations/0001_init.sql
#   3. Authentication → Users → Add user (email/password) com a senha do admin
SUPABASE_URL=https://xxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxx

# Lista de emails autorizados a logar no /admin (separados por vírgula)
ADMIN_EMAILS=contato@prtracker.com.br

# Meta Marketing API — System User token de PR_Tracker_Ads_CLI
# (mesmo do Tráfego/.env). Usado pelo cron de ingestão.
META_ACCESS_TOKEN=EAAxxxxxxxxxxxx
META_AD_ACCOUNT_ID=act_1936343516981196
META_API_VERSION=v23.0

# GA4 property ID (já detectado via Windsor: 525987283)
GA4_PROPERTY_ID=525987283

# Windsor.ai — gerar API key em
# https://windsor.ai/account/integrations/?tab=api
# Pulla GA4 + futuramente TikTok / ML / Amazon / Shopee.
WINDSOR_API_KEY=xxxxxxxx

# Resend (opcional) — envio de emails de alertas críticos.
# Pular se não quiser email; alertas continuam visíveis no dashboard.
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
ALERT_EMAIL_FROM=PR Tracker Alerts <onboarding@resend.dev>
ALERT_EMAIL_TO=contato@prtracker.com.br

# Cron secret — string aleatória usada pra autenticar Vercel Cron callbacks.
# Gerar com `openssl rand -hex 32` ou similar.
CRON_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
