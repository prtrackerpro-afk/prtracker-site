---
import X from "@lucide/astro/icons/x";
import ShoppingBag from "@lucide/astro/icons/shopping-bag";
---

<aside
  class="cart-drawer"
  data-cart-drawer
  aria-hidden="true"
  aria-labelledby="cart-drawer-title"
  role="dialog"
>
  <div class="cart-drawer__overlay" data-cart-close aria-hidden="true"></div>

  <div class="cart-drawer__panel" role="document">
    <header class="cart-drawer__header">
      <h2 id="cart-drawer-title" class="cart-drawer__title">Seu Carrinho</h2>
      <button
        type="button"
        class="cart-drawer__close"
        aria-label="Fechar carrinho"
        data-cart-close
      >
        <X size={22} aria-hidden="true" />
      </button>
    </header>

    <div class="cart-drawer__body" data-cart-body>
      <!-- Empty state -->
      <div class="cart-drawer__empty" data-cart-empty>
        <ShoppingBag size={48} aria-hidden="true" />
        <p class="cart-drawer__empty-title">Seu carrinho está vazio</p>
        <p class="cart-drawer__empty-subtitle">Adicione um troféu para continuar.</p>
        <a href="/#produtos" class="btn btn-primary mt-6" data-cart-close>Ver produtos</a>
      </div>

      <!-- Items (rendered by JS) -->
      <ul class="cart-drawer__items" data-cart-items hidden></ul>
    </div>

    <footer class="cart-drawer__footer" data-cart-footer hidden>
      <div class="cart-drawer__totals">
        <div class="cart-drawer__line">
          <span class="text-brand-gray">Subtotal</span>
          <span class="font-semibold" data-cart-subtotal>R$ 0,00</span>
        </div>
        <div class="cart-drawer__line cart-drawer__line--pix">
          <span>
            <span class="pix-badge">Pix</span>
            <span class="text-sm text-brand-gray ml-2">5 % OFF no total</span>
          </span>
          <span class="cart-drawer__pix-price" data-cart-pix-total>R$ 0,00</span>
        </div>
      </div>

      <div class="cart-drawer__actions">
        <button
          type="button"
          class="btn btn-outline flex-1"
          data-cart-close
        >Continuar</button>
        <a href="/checkout" class="btn btn-primary flex-1">Finalizar</a>
      </div>
    </footer>
  </div>
</aside>

<style>
  .cart-drawer {
    position: fixed;
    inset: 0;
    z-index: 100;
    pointer-events: none;
    visibility: hidden;
  }
  .cart-drawer[aria-hidden="false"] {
    pointer-events: auto;
    visibility: visible;
  }

  .cart-drawer__overlay {
    position: absolute;
    inset: 0;
    background: rgb(1 0 42 / 0.55);
    opacity: 0;
    transition: opacity 280ms ease;
  }
  .cart-drawer[aria-hidden="false"] .cart-drawer__overlay {
    opacity: 1;
  }

  .cart-drawer__panel {
    position: absolute;
    inset: 0 0 0 auto;
    width: min(420px, 100%);
    background: var(--color-brand-white);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 320ms cubic-bezier(0.32, 0.72, 0.16, 1);
    box-shadow: -10px 0 40px rgb(1 0 42 / 0.2);
  }
  .cart-drawer[aria-hidden="false"] .cart-drawer__panel {
    transform: translateX(0);
  }

  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid rgb(1 0 42 / 0.08);
  }
  .cart-drawer__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.015em;
    color: var(--color-brand-navy);
    margin: 0;
  }
  .cart-drawer__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 9999px;
    background: transparent;
    color: var(--color-brand-navy);
    border: none;
    cursor: pointer;
    transition: background-color 150ms ease;
  }
  .cart-drawer__close:hover { background: rgb(1 0 42 / 0.06); }

  .cart-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: 1rem 1.5rem;
  }
  .cart-drawer__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 3rem 1rem;
    color: var(--color-brand-gray);
  }
  .cart-drawer__empty-title {
    margin-top: 1rem;
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-brand-navy);
  }
  .cart-drawer__empty-subtitle {
    margin-top: 0.5rem;
    font-size: 0.95rem;
  }

  .cart-drawer__items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .cart-item {
    display: grid;
    grid-template-columns: 72px 1fr auto;
    gap: 1rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgb(1 0 42 / 0.06);
  }
  .cart-item:last-child { border-bottom: none; padding-bottom: 0; }
  .cart-item__img {
    width: 72px;
    height: 72px;
    object-fit: contain;
    background: #f7f7fb;
    border-radius: 0.75rem;
  }
  .cart-item__meta {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }
  .cart-item__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    line-height: 1.3;
    color: var(--color-brand-navy);
    margin: 0;
  }
  .cart-item__config {
    font-size: 0.8rem;
    color: var(--color-brand-gray);
    line-height: 1.4;
  }
  .cart-item__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 0.35rem;
  }
  .cart-item__qty {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    border: 1px solid rgb(1 0 42 / 0.12);
    border-radius: 9999px;
    overflow: hidden;
  }
  .cart-item__qty button {
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    color: var(--color-brand-navy);
    cursor: pointer;
    transition: background-color 120ms ease;
  }
  .cart-item__qty button:hover { background: rgb(1 0 42 / 0.05); }
  .cart-item__qty-value {
    min-width: 1.5rem;
    text-align: center;
    font-weight: 600;
    font-size: 0.9rem;
  }
  .cart-item__price {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-brand-navy);
    font-size: 0.95rem;
  }
  .cart-item__remove {
    align-self: flex-start;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: var(--color-brand-gray);
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    transition: color 150ms ease, background-color 150ms ease;
  }
  .cart-item__remove:hover {
    color: #b91c1c;
    background: rgb(185 28 28 / 0.08);
  }

  .cart-drawer__footer {
    padding: 1.25rem 1.5rem;
    border-top: 1px solid rgb(1 0 42 / 0.08);
    background: #fafafc;
  }
  .cart-drawer__totals {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .cart-drawer__line {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 1rem;
  }
  .cart-drawer__line--pix {
    color: var(--color-brand-navy);
  }
  .cart-drawer__pix-price {
    font-family: var(--font-display);
    font-weight: 800;
    color: #16a34a;
    font-size: 1.125rem;
  }
  .pix-badge {
    display: inline-block;
    background: var(--color-brand-lime);
    color: var(--color-brand-navy);
    padding: 0.2rem 0.65rem;
    border-radius: 9999px;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .cart-drawer__actions {
    display: flex;
    gap: 0.75rem;
  }
</style>

<script>
  import { cart } from "~/scripts/cart";
  import type { CartSnapshot } from "~/lib/cart-types";
  import { formatBRL } from "~/lib/format";
  import { formatCartItemDisplay, escapeHtml } from "~/lib/cart-format";

  const drawer = document.querySelector<HTMLElement>("[data-cart-drawer]");
  if (!drawer) throw new Error("CartDrawer: root element not found");

  const empty = drawer.querySelector<HTMLElement>("[data-cart-empty]")!;
  const itemsList = drawer.querySelector<HTMLUListElement>("[data-cart-items]")!;
  const footer = drawer.querySelector<HTMLElement>("[data-cart-footer]")!;
  const subtotalEl = drawer.querySelector<HTMLElement>("[data-cart-subtotal]")!;
  const pixEl = drawer.querySelector<HTMLElement>("[data-cart-pix-total]")!;

  // Latest snapshot kept in scope so click handlers don't re-read localStorage.
  let snap: CartSnapshot = cart.snapshot();

  function render(next: CartSnapshot) {
    snap = next;
    if (snap.items.length === 0) {
      empty.hidden = false;
      itemsList.hidden = true;
      footer.hidden = true;
      return;
    }
    empty.hidden = true;
    itemsList.hidden = false;
    footer.hidden = false;

    itemsList.innerHTML = snap.items
      .map((item) => {
        const display = formatCartItemDisplay(item);
        const subHtml =
          display.subLines.length > 0
            ? `<p class="cart-item__config">${display.subLines.map((l) => escapeHtml(l)).join("<br/>")}</p>`
            : "";
        return `
          <li class="cart-item" data-id="${escapeHtml(item.id)}">
            <img src="${escapeHtml(item.image)}" alt="" class="cart-item__img" width="72" height="72" loading="lazy" />
            <div class="cart-item__meta">
              <p class="cart-item__title">${escapeHtml(item.title)}${escapeHtml(display.titleSuffix)}</p>
              ${subHtml}
              <div class="cart-item__row">
                <div class="cart-item__qty" role="group" aria-label="Quantidade">
                  <button type="button" aria-label="Diminuir" data-qty-down>
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  </button>
                  <span class="cart-item__qty-value">${item.quantity}</span>
                  <button type="button" aria-label="Aumentar" data-qty-up>
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  </button>
                </div>
                <span class="cart-item__price">${formatBRL(item.unitPriceCents * item.quantity)}</span>
              </div>
            </div>
            <button type="button" class="cart-item__remove" aria-label="Remover" data-remove>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/></svg>
            </button>
          </li>
        `;
      })
      .join("");

    subtotalEl.textContent = formatBRL(snap.subtotalCents);
    pixEl.textContent = formatBRL(snap.pixTotalCents);
  }

  render(snap);

  document.addEventListener("cart:change", (ev) => {
    render((ev as CustomEvent<CartSnapshot>).detail ?? cart.snapshot());
  });

  itemsList.addEventListener("click", (ev) => {
    const target = ev.target as HTMLElement;
    const li = target.closest<HTMLLIElement>(".cart-item");
    if (!li) return;
    const id = li.dataset.id!;
    const current = snap.items.find((i) => i.id === id);
    if (!current) return;
    if (target.closest("[data-qty-down]")) {
      cart.updateQuantity(id, current.quantity - 1);
    } else if (target.closest("[data-qty-up]")) {
      cart.updateQuantity(id, current.quantity + 1);
    } else if (target.closest("[data-remove]")) {
      cart.remove(id);
    }
  });

  // Open / close
  function openDrawer() {
    drawer.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  }
  function closeDrawer() {
    drawer.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  document.addEventListener("cart:open", openDrawer);
  document.addEventListener("cart:close", closeDrawer);

  drawer.querySelectorAll("[data-cart-close]").forEach((el) => {
    el.addEventListener("click", closeDrawer);
  });

  // ESC key closes
  document.addEventListener("keydown", (ev) => {
    if (ev.key === "Escape" && drawer.getAttribute("aria-hidden") === "false") {
      closeDrawer();
    }
  });
</script>
