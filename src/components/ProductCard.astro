---
import type { CollectionEntry } from "astro:content";
import { formatBRL } from "~/lib/format";
import ArrowRight from "@lucide/astro/icons/arrow-right";

interface Props {
  product: CollectionEntry<"products">;
  /** Prioritize image loading (hero cards). */
  eager?: boolean;
}

const { product, eager = false } = Astro.props;
const { title, tagline, priceBase, priceFrom, images, slug } = product.data;
const primary = images[0]!;

/**
 * When the primary image ships alongside WebP/AVIF siblings (via
 * scripts/build-image-variants.mjs), serve them first — modern browsers
 * save ~50-70% vs JPG. Legacy browsers fall through to the <img>.
 *
 * For product hero shots (path ending in /hero.jpg) we use the "card"
 * variant resized to 800×592 — the full 1800×1333 is ~3× overkill for a
 * 394×292 card. Non-hero sources (camisetas, anilhas) use the normal
 * base since they're already close to display size.
 */
const rawBase = primary.src.replace(/\.(jpe?g|png)$/i, "");
const isHeroShot = /\/hero$/.test(rawBase);
const variantBase = isHeroShot ? `${rawBase}.card` : rawBase;
const hasVariants = /\.(jpe?g|png)$/i.test(primary.src);
---

<a href={`/product/${slug}`} class="product-card" aria-label={`${title} — ver produto`}>
  <div class="product-card__media">
    <picture>
      {hasVariants && <source type="image/avif" srcset={`${variantBase}.avif`} />}
      {hasVariants && <source type="image/webp" srcset={`${variantBase}.webp`} />}
      <img
        src={primary.src}
        alt={primary.alt}
        width={primary.width ?? 800}
        height={primary.height ?? 800}
        loading={eager ? "eager" : "lazy"}
        decoding="async"
        fetchpriority={eager ? "high" : "auto"}
        class="product-card__img"
      />
    </picture>
  </div>

  <div class="product-card__body">
    <h3 class="product-card__title">{title}</h3>
    {tagline && <p class="product-card__tagline">{tagline}</p>}

    <p class="product-card__price">
      {priceFrom && <span class="product-card__price-prefix">A partir de</span>}
      <span class="product-card__price-value">{formatBRL(priceBase)}</span>
    </p>

    <span class="product-card__cta" aria-hidden="true">
      <span>SAIBA MAIS</span>
      <ArrowRight size={16} />
    </span>
  </div>
</a>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    background: var(--color-brand-white);
    border: 1.5px solid var(--color-brand-navy);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-card);
    transition: box-shadow 220ms ease, transform 220ms ease, border-color 220ms ease;
    height: 100%;
  }
  .product-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-4px);
  }
  .product-card:hover .product-card__img { transform: scale(1.04); }
  .product-card:hover .product-card__cta {
    background: var(--color-brand-lime);
    color: var(--color-brand-navy);
    border-color: var(--color-brand-lime);
  }

  .product-card__media {
    aspect-ratio: 3550 / 2624;  /* matches source hero shots */
    background: var(--color-brand-white);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-bottom: 1px solid rgb(1 0 42 / 0.08);
  }
  .product-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-card__body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    text-align: center;
    flex: 1;
  }
  .product-card__title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.1;
    color: var(--color-brand-navy);
    margin: 0;
    text-transform: uppercase;
  }
  .product-card__tagline {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-brand-gray);
    margin: 0;
    line-height: 1.4;
  }
  .product-card__price {
    margin: 0.4rem 0 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    line-height: 1.1;
  }
  .product-card__price-prefix {
    font-size: 0.78rem;
    color: var(--color-brand-gray);
    font-weight: 500;
  }
  .product-card__price-value {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.35rem;
    color: var(--color-brand-navy);
  }

  .product-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.9rem;
    padding: 0.55rem 1.2rem;
    border: 1.5px solid var(--color-brand-navy);
    border-radius: 9999px;
    background: transparent;
    color: var(--color-brand-navy);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: background-color 180ms ease, color 180ms ease, border-color 180ms ease;
  }
</style>
