---
import type { CollectionEntry } from "astro:content";
import { formatBRL } from "~/lib/format";
import ArrowRight from "@lucide/astro/icons/arrow-right";

interface Props {
  product: CollectionEntry<"products">;
  /** Prioritize image loading (hero cards). */
  eager?: boolean;
  /** Ordering index for the serial number. */
  index?: number;
}

/**
 * Per-product plate color coding — turns the IWF palette into a brand system.
 * Each product gets a signature color drawn from its closest-weight plate.
 */
const PLATE_ACCENT: Record<string, { color: string; weight: string }> = {
  "power-rack-set":                { color: "var(--color-plate-10)",  weight: "10KG" },
  "bench-press-set":                { color: "var(--color-plate-25)",  weight: "25KG" },
  "deadlift-set":                   { color: "var(--color-plate-15)",  weight: "15KG" },
  "my-pr-set":                      { color: "var(--color-plate-20)",  weight: "20KG" },
  "anilhas":                        { color: "var(--color-plate-5)",   weight: "OPEN" },
  "camiseta-masculina":             { color: "var(--color-brand-navy)", weight: "FIT-M" },
  "camiseta-feminina-baby-look":    { color: "var(--color-brand-lime)", weight: "FIT-F" },
};

const { product, eager = false, index } = Astro.props;
const { title, tagline, priceBase, priceFrom, images, slug } = product.data;
const primary = images[0]!;

const accent = PLATE_ACCENT[slug] ?? { color: "var(--color-brand-navy)", weight: "" };
const serial = index !== undefined ? String(index + 1).padStart(2, "0") : "";
---

<a href={`/product/${slug}`} class="product-card" aria-label={`${title} — ver produto`}>
  <!-- Top metadata row -->
  <header class="product-card__meta">
    <span class="product-card__serial">
      {serial ? `// PR·${serial}` : "// SKU"}
    </span>
    <span class="product-card__weight">{accent.weight}</span>
  </header>

  <!-- Media -->
  <div class="product-card__media" style={`--accent: ${accent.color}`}>
    <span class="product-card__crosshair" aria-hidden="true"></span>
    <img
      src={primary.src}
      alt={primary.alt}
      width={primary.width ?? 800}
      height={primary.height ?? 800}
      loading={eager ? "eager" : "lazy"}
      decoding="async"
      fetchpriority={eager ? "high" : "auto"}
      class="product-card__img"
    />
  </div>

  <!-- Accent stripe (IWF plate color) -->
  <span class="product-card__stripe" style={`background: ${accent.color}`} aria-hidden="true"></span>

  <!-- Body -->
  <div class="product-card__body">
    <h3 class="product-card__title">{title}</h3>
    {tagline && <p class="product-card__tagline">{tagline}</p>}

    <footer class="product-card__foot">
      <div class="product-card__price">
        {priceFrom && <span class="product-card__price-prefix">A PARTIR DE</span>}
        <span class="product-card__price-value">{formatBRL(priceBase)}</span>
      </div>
      <span class="product-card__cta" aria-hidden="true">
        <span>VER</span>
        <ArrowRight size={16} />
      </span>
    </footer>
  </div>
</a>

<style>
  .product-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-brand-white);
    border: 1px solid rgb(1 0 42 / 0.15);
    border-radius: var(--radius-card);
    text-decoration: none;
    color: inherit;
    transition: transform 220ms ease, box-shadow 220ms ease;
    overflow: hidden;
  }
  .product-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 6px 6px 0 0 var(--color-brand-navy);
  }
  .product-card:hover .product-card__img { transform: scale(1.04); }
  .product-card:hover .product-card__cta {
    background: var(--color-brand-navy);
    color: var(--color-brand-lime);
  }

  /* ------- Meta row ------- */
  .product-card__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-brand-gray);
    border-bottom: 1px dashed rgb(1 0 42 / 0.15);
  }
  .product-card__weight {
    color: var(--color-brand-navy);
    font-weight: 700;
  }

  /* ------- Media ------- */
  .product-card__media {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--color-paper);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem;
    overflow: hidden;
  }
  .product-card__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--accent) 0%, transparent 35%);
    opacity: 0.08;
    pointer-events: none;
  }

  .product-card__crosshair {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 18px;
    height: 18px;
    border: 1px solid var(--accent);
    opacity: 0.4;
  }
  .product-card__crosshair::before,
  .product-card__crosshair::after {
    content: "";
    position: absolute;
    background: var(--accent);
  }
  .product-card__crosshair::before {
    inset: 50% -4px auto -4px;
    height: 1px;
  }
  .product-card__crosshair::after {
    inset: -4px 50% -4px auto;
    width: 1px;
  }

  .product-card__img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
    filter: drop-shadow(0 8px 16px rgb(1 0 42 / 0.08));
  }

  /* ------- Stripe ------- */
  .product-card__stripe {
    display: block;
    height: 6px;
    width: 100%;
  }

  /* ------- Body ------- */
  .product-card__body {
    padding: 1.25rem 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .product-card__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.1vw + 1rem, 1.875rem);
    font-weight: 800;
    letter-spacing: -0.005em;
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--color-brand-navy);
    margin: 0;
  }
  .product-card__tagline {
    font-family: var(--font-body);
    font-size: 0.92rem;
    color: var(--color-brand-gray);
    margin: 0;
    line-height: 1.45;
  }

  .product-card__foot {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-top: auto;
    padding-top: 1rem;
    gap: 1rem;
  }
  .product-card__price {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    line-height: 1;
  }
  .product-card__price-prefix {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--color-brand-gray);
  }
  .product-card__price-value {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.45rem;
    color: var(--color-brand-navy);
    letter-spacing: -0.01em;
  }

  .product-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0.85rem;
    background: transparent;
    color: var(--color-brand-navy);
    border: 1px solid var(--color-brand-navy);
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: background-color 180ms ease, color 180ms ease;
  }
</style>
