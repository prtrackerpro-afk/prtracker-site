---
import Mail from "@lucide/astro/icons/mail";
import Logo from "./Logo.astro";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container-page py-16 grid gap-10 md:grid-cols-4">
    <div class="md:col-span-2">
      <Logo variant="light" size="lg" />
      <p class="mt-5 text-white/70 max-w-md leading-relaxed">
        Miniaturas premium que transformam seu PR em troféu.
        Seu PR merece mais do que uma foto.
      </p>
      <div class="mt-6 flex items-center gap-3">
        <a
          href="https://instagram.com/pr.tracker"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram @pr.tracker"
          class="social-link"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
          </svg>
        </a>
        <a
          href="https://wa.me/5551982061914"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="WhatsApp (51) 98206-1914"
          class="social-link"
        >
          <!-- WhatsApp inline SVG (no lucide icon) -->
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.768.966-.941 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.85 12.85 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.695.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
          </svg>
        </a>
        <a href="mailto:contato@prtracker.com.br" aria-label="E-mail contato@prtracker.com.br" class="social-link">
          <Mail size={18} aria-hidden="true" />
        </a>
      </div>
    </div>

    <div>
      <h3 class="footer-title">Navegação</h3>
      <ul class="footer-list">
        <li><a href="/#produtos">Produtos</a></li>
        <li><a href="/product-category/camisetas">Camisetas</a></li>
        <li><a href="/#como-funciona">Como funciona</a></li>
        <li><a href="/contato">Contato</a></li>
      </ul>
    </div>

    <div>
      <h3 class="footer-title">Atendimento</h3>
      <ul class="footer-list">
        <li><a href="https://wa.me/5551982061914" target="_blank" rel="noopener noreferrer">(51) 98206-1914</a></li>
        <li><a href="mailto:contato@prtracker.com.br">contato@prtracker.com.br</a></li>
        <li class="text-white/60">Seg a Sex · 8h às 18h</li>
      </ul>
      <h3 class="footer-title mt-8">Políticas</h3>
      <ul class="footer-list">
        <li><a href="/politicas/privacidade">Privacidade</a></li>
        <li><a href="/politicas/troca-e-devolucao">Troca e devolução</a></li>
        <li><a href="/politicas/termos">Termos de uso</a></li>
      </ul>
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="container-page py-6 flex flex-col md:flex-row items-center justify-between gap-3 text-sm text-white/60">
      <p>© {year} PR Tracker Ltda · CNPJ 59.947.215/0001-67</p>
      <p>Envio para todo o Brasil · Pagamento via Pix ou cartão</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-brand-navy);
    color: var(--color-brand-white);
  }
  .footer-title {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-brand-lime);
    margin-bottom: 1rem;
  }
  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .footer-list a {
    color: rgb(255 255 255 / 0.8);
    text-decoration: none;
    transition: color 120ms ease;
  }
  .footer-list a:hover { color: var(--color-brand-lime); }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 9999px;
    background: rgb(255 255 255 / 0.08);
    color: var(--color-brand-white);
    transition: background-color 150ms ease, color 150ms ease;
  }
  .social-link:hover {
    background: var(--color-brand-lime);
    color: var(--color-brand-navy);
  }

  .site-footer__bottom {
    background: #000;
  }
</style>
