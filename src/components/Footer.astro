<style>
  .site-footer {
    background: var(--color-brand-navy);
    color: var(--color-brand-white);
    border-top: 1px solid rgb(216 255 44 / 0.2);
  }

  .site-footer__spec {
    display: grid;
    gap: 2.5rem;
    padding-block: 4rem 3rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .site-footer__spec { grid-template-columns: 1.3fr 1fr 1.1fr 1fr; gap: 3rem; }
  }

  .site-footer__spec-col {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .site-footer__manifesto {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(1.75rem, 2vw + 1rem, 2.75rem);
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--color-brand-white);
    margin: 0.5rem 0 0;
  }
  .site-footer__tag {
    color: rgb(255 255 255 / 0.65);
    font-size: 0.92rem;
    max-width: 30ch;
    margin: 0;
    line-height: 1.55;
  }

  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .footer-list a {
    color: rgb(255 255 255 / 0.8);
    text-decoration: none;
    font-size: 0.92rem;
    transition: color 120ms ease;
  }
  .footer-list a:hover { color: var(--color-brand-lime); }
  .footer-list__meta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.5);
  }

  .site-footer__social {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }
  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.5rem 0;
    color: rgb(255 255 255 / 0.8);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-bottom: 1px solid rgb(255 255 255 / 0.08);
    transition: color 150ms ease, border-color 150ms ease;
  }
  .social-link:hover {
    color: var(--color-brand-lime);
    border-color: var(--color-brand-lime);
  }

  .site-footer__wordmark {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(4rem, 18vw, 16rem);
    line-height: 0.85;
    letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 1px rgb(216 255 44 / 0.35);
    text-stroke: 1px rgb(216 255 44 / 0.35);
    padding-block: 1rem 2.5rem;
    user-select: none;
    overflow: hidden;
    white-space: nowrap;
    text-transform: uppercase;
  }
  .site-footer__wordmark-dot {
    color: var(--color-brand-lime);
    -webkit-text-stroke: 0;
    margin: 0 0.15em;
  }

  .site-footer__bottom {
    background: #000;
    border-top: 1px solid rgb(255 255 255 / 0.05);
  }
  .site-footer__bottom-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    align-items: center;
    padding-block: 1rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.5);
  }
  .site-footer__bottom-inner .sep { color: rgb(216 255 44 / 0.5); }
</style>
