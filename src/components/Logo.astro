---
/**
 * PR Tracker logotype — official MIV asset.
 *
 * Variants:
 *  - dark  → navy wordmark on light background (`logo-navy.png`)
 *  - light → lime wordmark on dark background (`logo-lime.png`)
 */

interface Props {
  variant?: "dark" | "light";
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { variant = "dark", size = "md", class: cls = "" } = Astro.props;

const src = variant === "light"
  ? "/images/brand/logo-lime.png"
  : "/images/brand/logo-navy.png";

const heights: Record<typeof size, string> = { sm: "1.75rem", md: "2.25rem", lg: "3.25rem" };
const height = heights[size];
---

<span class={`pr-logo ${cls}`} style={`height: ${height};`}>
  <img
    src={src}
    alt="PR Tracker"
    width="820"
    height="280"
    loading="eager"
    decoding="async"
  />
</span>

<style>
  .pr-logo {
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }
  .pr-logo img {
    height: 100%;
    width: auto;
    display: block;
    object-fit: contain;
  }
</style>
