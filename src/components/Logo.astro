---
/**
 * PR Tracker logotype.
 * Mark: miniature-barbell icon (navy rounded square + lime bar + IWF plates)
 *       mirroring the favicon so the brand reads the same at every scale.
 * Wordmark: "PR TRACKER" in Big Shoulders bold, tight kerning.
 */

interface Props {
  variant?: "dark" | "light";
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { variant = "dark", size = "md", class: cls = "" } = Astro.props;

const wordmarkColor = variant === "light" ? "#FFFFFF" : "#01002A";
const markBg        = variant === "light" ? "#01002A" : "#01002A";

const heights: Record<typeof size, string> = { sm: "1.6rem", md: "2.1rem", lg: "2.75rem" };
const height = heights[size];
---

<a
  class={`pr-logo inline-flex items-center gap-2.5 ${cls}`}
  style={`height: ${height};`}
  aria-label="PR Tracker"
  role="img"
>
  <svg
    viewBox="0 0 64 64"
    style="height: 100%; width: auto; display: block;"
    aria-hidden="true"
    focusable="false"
  >
    <rect width="64" height="64" rx="12" fill={markBg} />
    <!-- Lime bar -->
    <rect x="6"  y="28" width="52" height="8"  rx="2"   fill="#D8FF2C" />
    <!-- Outer plates (red = 25 kg) -->
    <rect x="10" y="20" width="8"  height="24" rx="1.5" fill="#DA291C" />
    <rect x="46" y="20" width="8"  height="24" rx="1.5" fill="#DA291C" />
    <!-- Inner plates (blue = 20 kg) -->
    <rect x="20" y="24" width="5"  height="16" rx="1"   fill="#0057B8" />
    <rect x="39" y="24" width="5"  height="16" rx="1"   fill="#0057B8" />
  </svg>
  <span class="pr-logo__wordmark" style={`color: ${wordmarkColor};`}>
    PR&nbsp;TRACKER
  </span>
</a>

<style>
  .pr-logo { text-decoration: none; }
  .pr-logo__wordmark {
    font-family: var(--font-logo);
    font-weight: 900;
    font-size: calc(1em * 0.88);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    line-height: 1;
    white-space: nowrap;
  }
</style>
