---
/**
 * PR Tracker logotype — official MIV asset.
 *
 * Variants:
 *  - dark  → navy wordmark on light background (`logo-navy.png`)
 *  - light → lime wordmark on dark background (`logo-lime.png`)
 *
 * Sizes use CSS classes (not inline styles) so external @media queries
 * can override them without fighting inline-style specificity. Mobile
 * auto-shrinks to ~60 % of the `md` size.
 */

interface Props {
  variant?: "dark" | "light";
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { variant = "dark", size = "md", class: cls = "" } = Astro.props;

const base = variant === "light"
  ? "/images/brand/logo-lime"
  : "/images/brand/logo-navy";

// logo-lime has AVIF/WebP siblings (see scripts/build-image-variants.mjs).
// logo-navy only has PNG, so we fall through to the <img> for it.
const hasModernVariants = variant === "light";
---

<span class:list={["pr-logo", `pr-logo--${size}`, cls]}>
  <picture>
    {hasModernVariants && <source type="image/avif" srcset={`${base}.avif`} />}
    {hasModernVariants && <source type="image/webp" srcset={`${base}.webp`} />}
    <img
      src={`${base}.png`}
      alt="PR Tracker"
      width="820"
      height="280"
      loading="eager"
      decoding="async"
    />
  </picture>
</span>

<style>
  .pr-logo {
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }
  .pr-logo img {
    height: 100%;
    width: auto;
    display: block;
    object-fit: contain;
  }

  /* Desktop heights — inline style would have specificity 1,0,0,0 which
     beats every scoped rule, so we use classes that can be overridden by
     the mobile media query below. */
  .pr-logo--sm { height: 1.75rem; }
  .pr-logo--md { height: 2.25rem; }
  .pr-logo--lg { height: 3.25rem; }

  /* Breakpoint aligned with the hero's 899px — iPhone 15-class phones
     sometimes report CSS widths between 640-900 depending on zoom/DynamicType,
     which made the old 640px breakpoint miss. 899 guarantees every
     phone-sized viewport catches the rule, same as every other mobile
     override in this codebase. */
  @media (max-width: 899px) {
    .pr-logo--sm { height: 1.35rem !important; max-height: 1.35rem !important; }
    .pr-logo--md { height: 1.1rem !important; max-height: 1.1rem !important; }
    .pr-logo--lg { height: 2rem !important; max-height: 2rem !important; }
    /* Belt-and-suspenders: cap the <img> too, in case something jams the
       span open (flex alignment bug, parent height constraint, etc). */
    .pr-logo img { max-height: 100% !important; }
  }
</style>
