---
/**
 * PR Tracker logotype — SPECIMEN treatment.
 * Symbol: reduced to a blunt barbell silhouette. Wordmark in Big Shoulders,
 * uppercase, tight kerning — built for high-contrast technical layouts.
 */

interface Props {
  variant?: "dark" | "light" | "lime";
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { variant = "dark", size = "md", class: cls = "" } = Astro.props;

const colors = {
  dark:  { primary: "#01002A", accent: "#D8FF2C" },
  light: { primary: "#FFFFFF", accent: "#D8FF2C" },
  lime:  { primary: "#D8FF2C", accent: "#01002A" },
};
const c = colors[variant];

const heights: Record<typeof size, string> = { sm: "1.5rem", md: "2rem", lg: "2.75rem" };
const height = heights[size];
---

<span
  class={`pr-logo inline-flex items-center gap-2.5 ${cls}`}
  style={`height: ${height};`}
  role="img"
  aria-label="PR Tracker"
>
  <svg
    viewBox="0 0 48 32"
    style="height: 100%; width: auto;"
    aria-hidden="true"
    focusable="false"
  >
    <!-- Sleeves (plate ends) -->
    <rect x="0" y="6" width="5" height="20" fill={c.accent} />
    <rect x="43" y="6" width="5" height="20" fill={c.accent} />
    <!-- Inner plates -->
    <rect x="7" y="9" width="3" height="14" fill={c.primary} />
    <rect x="38" y="9" width="3" height="14" fill={c.primary} />
    <!-- Bar -->
    <rect x="10" y="14" width="28" height="4" fill={c.primary} />
  </svg>
  <span class="pr-logo__wordmark" style={`color: ${c.primary};`}>
    PR&nbsp;TRACKER
  </span>
</span>

<style>
  .pr-logo__wordmark {
    font-family: var(--font-logo);
    font-weight: 900;
    font-size: calc(1em * 0.95);
    letter-spacing: 0.01em;
    text-transform: uppercase;
    line-height: 1;
    white-space: nowrap;
  }
</style>
