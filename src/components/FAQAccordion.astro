---
interface FAQItem { question: string; answer: string; }

interface Props {
  items: FAQItem[];
  title?: string;
}

const { items, title = "Dúvidas frequentes" } = Astro.props;
---

{items.length > 0 && (
  <section class="faq" aria-labelledby="faq-title">
    <h2 id="faq-title" class="faq__title">{title}</h2>
    <div class="faq__list">
      {items.map((item) => (
        <details class="faq__item">
          <summary class="faq__question">
            <span>{item.question}</span>
            <svg class="faq__chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </summary>
          <div class="faq__answer">
            <p>{item.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </section>
)}

<style>
  .faq { margin-top: 3rem; }
  .faq__title {
    font-size: 1.5rem;
    margin: 0 0 1.25rem;
  }
  .faq__list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid rgb(1 0 42 / 0.08);
  }
  .faq__item {
    border-bottom: 1px solid rgb(1 0 42 / 0.08);
  }
  .faq__question {
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1.125rem 0;
    cursor: pointer;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-brand-navy);
    font-size: 1rem;
  }
  .faq__question::-webkit-details-marker { display: none; }
  .faq__question:hover { color: #141435; }

  .faq__chevron {
    color: var(--color-brand-gray);
    flex-shrink: 0;
    transition: transform 220ms ease;
  }
  .faq__item[open] .faq__chevron { transform: rotate(180deg); }

  .faq__answer {
    padding: 0 0 1.25rem;
    color: var(--color-brand-gray);
    line-height: 1.6;
  }
  .faq__answer p { margin: 0; max-width: 52rem; }
</style>
