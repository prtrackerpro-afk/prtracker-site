---
/**
 * GA4 + Meta Pixel. IDs públicos (aparecem no HTML client-side), hardcoded
 * pra manter o build simples.
 *
 * GA4 Measurement ID: stream "PR Tracker v2" da propriedade prtracker.com.br.
 * Note que NÃO usamos o Google Tag wrapper (GT-WBTC67LF) do WordPress —
 * aquele tag existe mas não está roteado pra essa propriedade GA4, então
 * dados nunca chegavam. Usando G- direto os hits vão pro Realtime em minutos.
 *
 * Meta Pixel: mesmo ID do WP atual, preserva audiência e conversões.
 */
const GA4_MEASUREMENT_ID = "G-B2EPJXKSPZ";
const META_PIXEL_ID = "1278981700843845";

const isDev = import.meta.env.DEV;
---

{
  !isDev && (
    <>
      {/* Google Analytics 4 (gtag.js) */}
      <script
        is:inline
        async
        src={`https://www.googletagmanager.com/gtag/js?id=${GA4_MEASUREMENT_ID}`}
      />
      <script is:inline define:vars={{ GA4_MEASUREMENT_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          window.dataLayer.push(arguments);
        }
        window.gtag = gtag;
        gtag("js", new Date());
        gtag("config", GA4_MEASUREMENT_ID);
      </script>

      {/*
        Meta Pixel — deferred until browser idle (or after load) so the
        ~130KB fbevents.js download + execution doesn't steal main-thread
        time during the LCP window. PageView still fires before most
        users leave: requestIdleCallback runs within 1-2s of load in
        typical mobile conditions, and a 3s setTimeout backs it up for
        browsers without rIC (Safari < 16).
      */}
      <script is:inline define:vars={{ META_PIXEL_ID }}>
        function loadMetaPixel() {
          if (window.fbq) return;
          !(function (f, b, e, v, n, t, s) {
            n = f.fbq = function () {
              n.callMethod
                ? n.callMethod.apply(n, arguments)
                : n.queue.push(arguments);
            };
            if (!f._fbq) f._fbq = n;
            n.push = n;
            n.loaded = !0;
            n.version = "2.0";
            n.queue = [];
            t = b.createElement(e);
            t.async = !0;
            t.src = v;
            s = b.getElementsByTagName(e)[0];
            s.parentNode.insertBefore(t, s);
          })(
            window,
            document,
            "script",
            "https://connect.facebook.net/en_US/fbevents.js"
          );
          // Disable autoConfig BEFORE init: kills Meta's microdata-based
          // automatic AddToCart/SubscribedButtonClick (`es=automatic`,
          // `est_source=...`) that fires from button-text heuristics with
          // no Event ID and no params, polluting CTR/CPA. We send our own
          // events with full custom_data + eventID for CAPI dedup.
          fbq("set", "autoConfig", "false", META_PIXEL_ID);
          fbq("init", META_PIXEL_ID);
          fbq("track", "PageView");
        }
        if ("requestIdleCallback" in window) {
          requestIdleCallback(loadMetaPixel, { timeout: 3000 });
        } else {
          setTimeout(loadMetaPixel, 2500);
        }
      </script>
      <noscript>
        <img
          height="1"
          width="1"
          style="display:none"
          src={`https://www.facebook.com/tr?id=${META_PIXEL_ID}&ev=PageView&noscript=1`}
          alt=""
        />
      </noscript>
    </>
  )
}
