---
interface Props {
  current: number;
  paramName?: string;
}
const { current, paramName = "days" } = Astro.props;
const options = [
  { value: 1, label: "Hoje" },
  { value: 7, label: "7d" },
  { value: 14, label: "14d" },
  { value: 30, label: "30d" },
  { value: 90, label: "90d" },
];
const currentUrl = new URL(Astro.request.url);
---

<div class="inline-flex rounded-lg border border-navy-700 bg-navy-800/40 p-0.5">
  {
    options.map((o) => {
      const url = new URL(currentUrl);
      url.searchParams.set(paramName, String(o.value));
      const active = current === o.value;
      return (
        <a
          href={url.pathname + url.search}
          class:list={[
            "rounded-md px-3 py-1.5 text-xs font-medium transition",
            active ? "bg-brand-lime text-navy-900" : "text-navy-200 hover:text-white",
          ]}
        >
          {o.label}
        </a>
      );
    })
  }
</div>
