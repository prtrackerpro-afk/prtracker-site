---
interface Props {
  label: string;
  value: string;
  delta?: { value: string; positive?: boolean };
  hint?: string;
  accent?: "lime" | "navy" | "default";
}
const { label, value, delta, hint, accent = "default" } = Astro.props;

const accentClass =
  accent === "lime"
    ? "border-brand-lime/30 bg-brand-lime/5"
    : accent === "navy"
      ? "border-navy-700 bg-navy-800/40"
      : "border-navy-700 bg-navy-800/30";
---

<div class:list={["rounded-2xl border p-5 transition", accentClass]}>
  <div class="text-xs uppercase tracking-wider text-navy-300">{label}</div>
  <div class="mt-2 text-3xl font-semibold text-white">{value}</div>
  {
    delta && (
      <div
        class:list={[
          "mt-1 text-xs font-medium",
          delta.positive ? "text-emerald-400" : "text-red-400",
        ]}
      >
        {delta.positive ? "▲" : "▼"} {delta.value}
      </div>
    )
  }
  {hint && <div class="mt-1 text-xs text-navy-300">{hint}</div>}
</div>
