---
import Menu from "@lucide/astro/icons/menu";
import ShoppingBag from "@lucide/astro/icons/shopping-bag";
import X from "@lucide/astro/icons/x";
import Logo from "./Logo.astro";

interface Props {
  /** Kept for compatibility — header is now always solid. */
  transparent?: boolean;
}

const nav = [
  { href: "/",                              label: "Início" },
  { href: "/product/power-rack-set",        label: "Power Rack" },
  { href: "/product/bench-press-set",       label: "Bench Press" },
  { href: "/product/deadlift-set",          label: "Deadlift" },
  { href: "/product/my-pr-set",             label: "My PR Set" },
  { href: "/product-category/camisetas",    label: "Camisetas" },
  { href: "/product/anilhas",               label: "Anilhas" },
  { href: "/sobre",                         label: "Quem Somos" },
  { href: "/contato",                       label: "Contato" },
];
---

<header class="site-header">
  <a href="#main" class="skip-link">Pular para o conteúdo</a>

  <!-- Top promo strip -->
  <div class="site-header__promo" aria-hidden="false">
    <div class="container-page site-header__promo-inner">
      <span>PAGUE NO PIX E GANHE 5% DE DESCONTO</span>
    </div>
  </div>

  <!-- Main nav bar -->
  <div class="site-header__bar">
    <div class="container-page site-header__bar-inner">
      <a href="/" aria-label="PR Tracker — início" class="shrink-0">
        <Logo variant="light" size="md" />
      </a>

      <nav aria-label="Menu principal" class="site-header__nav">
        {nav.map((item) => (
          <a href={item.href} class="nav-link">{item.label}</a>
        ))}
      </nav>

      <div class="site-header__actions">
        <button
          type="button"
          class="icon-btn"
          aria-label="Abrir carrinho"
          data-cart-open
        >
          <ShoppingBag size={20} aria-hidden="true" />
          <span class="icon-btn__badge" data-cart-count aria-live="polite" aria-atomic="true" hidden>0</span>
        </button>

        <button
          type="button"
          class="icon-btn md:hidden"
          aria-label="Abrir menu"
          aria-expanded="false"
          data-mobile-menu-toggle
        >
          <Menu size={22} aria-hidden="true" class="icon-btn__open" />
          <X size={22} aria-hidden="true" class="icon-btn__close" />
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-nav" data-mobile-nav hidden>
    <nav aria-label="Menu mobile">
      {nav.map((item) => (
        <a href={item.href} class="mobile-nav__link" data-mobile-nav-link>{item.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-brand-navy);
    color: var(--color-brand-white);
  }

  /* Promo strip */
  .site-header__promo {
    background: var(--color-brand-lime);
    color: var(--color-brand-navy);
  }
  .site-header__promo-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    padding-block: 0.45rem;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* Main bar */
  .site-header__bar {
    background: var(--color-brand-navy);
    border-bottom: 1px solid rgb(255 255 255 / 0.06);
  }
  .site-header__bar-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    padding-block: 0.9rem;
  }
  /* Tighter header on phones — was eating ~90px of vertical space above
     the fold, pushing hero copy + CTAs too low on iPhone 15-class devices.
     :global(.pr-logo) because that span is rendered by Logo.astro with a
     different data-astro-cid scope — Astro would otherwise never match
     the selector. */
  @media (max-width: 640px) {
    .site-header__bar-inner { padding-block: 0.5rem; }
    .site-header__promo-inner { padding-block: 0.35rem; font-size: 0.72rem; }
    :global(.pr-logo) { height: 1.1rem !important; }
    .icon-btn { width: 36px; height: 36px; }
  }

  /* Nav */
  .site-header__nav {
    display: none;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.4rem;
  }
  @media (min-width: 1080px) {
    .site-header__nav { display: flex; }
  }

  .nav-link {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-brand-white);
    text-decoration: none;
    position: relative;
    padding: 0.35rem 0;
    transition: color 150ms ease;
  }
  .nav-link::after {
    content: "";
    position: absolute;
    inset: auto 0 -4px 0;
    height: 2px;
    background: var(--color-brand-lime);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 200ms ease;
  }
  .nav-link:hover { color: var(--color-brand-lime); }
  .nav-link:hover::after { transform: scaleX(1); }

  /* Actions */
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .icon-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    background: transparent;
    color: var(--color-brand-white);
    border: 1px solid rgb(255 255 255 / 0.2);
    border-radius: 9999px;
    cursor: pointer;
    transition: background-color 150ms ease, color 150ms ease, border-color 150ms ease;
  }
  .icon-btn:hover {
    background: var(--color-brand-lime);
    color: var(--color-brand-navy);
    border-color: var(--color-brand-lime);
  }
  .icon-btn__badge {
    position: absolute;
    top: -4px;
    right: -4px;
    min-width: 20px;
    height: 20px;
    padding: 0 5px;
    background: var(--color-brand-lime);
    color: var(--color-brand-navy);
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 20px;
    text-align: center;
    border-radius: 9999px;
    border: 2px solid var(--color-brand-navy);
  }

  .icon-btn .icon-btn__close { display: none; }
  .icon-btn[aria-expanded="true"] .icon-btn__open { display: none; }
  .icon-btn[aria-expanded="true"] .icon-btn__close { display: inline-block; }

  @media (min-width: 1080px) {
    .icon-btn.md\:hidden { display: none !important; }
  }

  /* Mobile drawer */
  .mobile-nav {
    background: var(--color-brand-navy);
    border-top: 1px solid rgb(255 255 255 / 0.06);
    padding: 0.25rem 0;
  }
  @media (min-width: 1080px) { .mobile-nav { display: none; } }
  .mobile-nav nav {
    display: flex;
    flex-direction: column;
  }
  .mobile-nav__link {
    padding: 0.95rem 1.5rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-brand-white);
    text-decoration: none;
    border-bottom: 1px solid rgb(255 255 255 / 0.06);
  }
  .mobile-nav__link:last-child { border-bottom: none; }
  .mobile-nav__link:hover {
    background: var(--color-brand-lime);
    color: var(--color-brand-navy);
  }
</style>

<script>
  const mobileToggle = document.querySelector<HTMLButtonElement>("[data-mobile-menu-toggle]");
  const mobileNav = document.querySelector<HTMLElement>("[data-mobile-nav]");
  if (mobileToggle && mobileNav) {
    mobileToggle.addEventListener("click", () => {
      const open = mobileToggle.getAttribute("aria-expanded") === "true";
      mobileToggle.setAttribute("aria-expanded", String(!open));
      mobileNav.hidden = open;
    });
    mobileNav.querySelectorAll("[data-mobile-nav-link]").forEach((a) => {
      a.addEventListener("click", () => {
        mobileToggle.setAttribute("aria-expanded", "false");
        mobileNav.hidden = true;
      });
    });
  }

  document.querySelector("[data-cart-open]")?.addEventListener("click", () => {
    document.dispatchEvent(new CustomEvent("cart:open"));
  });

  const badge = document.querySelector<HTMLElement>("[data-cart-count]");
  if (badge) {
    document.addEventListener("cart:change", ((ev: CustomEvent) => {
      const count = ev.detail?.itemCount ?? 0;
      badge.textContent = String(count);
      badge.hidden = count === 0;
    }) as EventListener);
  }
</script>
