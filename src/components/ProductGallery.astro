---
interface GalleryImage {
  src: string;
  alt: string;
}

interface Props {
  images: GalleryImage[];
  title: string;
}

const { images, title } = Astro.props;
const primary = images[0]!;
---

<div class="gallery" data-gallery>
  <div class="gallery__main">
    <img
      src={primary.src}
      alt={primary.alt}
      width="800"
      height="800"
      class="gallery__img"
      data-gallery-main
      fetchpriority="high"
      loading="eager"
      decoding="async"
    />
  </div>

  {images.length > 1 && (
    <div class="gallery__thumbs" role="tablist" aria-label={`Imagens de ${title}`}>
      {images.map((img, idx) => (
        <button
          type="button"
          class:list={["gallery__thumb", idx === 0 && "is-active"]}
          data-gallery-thumb
          data-src={img.src}
          data-alt={img.alt}
          data-index={idx}
          role="tab"
          aria-selected={idx === 0 ? "true" : "false"}
          aria-label={`Imagem ${idx + 1} de ${images.length}`}
        >
          <img
            src={img.src}
            alt=""
            width="120"
            height="120"
            loading="lazy"
            decoding="async"
          />
        </button>
      ))}
    </div>
  )}
</div>

<style>
  .gallery {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .gallery__main {
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-card);
    background: #f7f7fb;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 4vw, 2.5rem);
    overflow: hidden;
  }
  .gallery__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: opacity 200ms ease;
  }
  .gallery__thumbs {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(72px, 1fr));
    gap: 0.625rem;
  }
  .gallery__thumb {
    aspect-ratio: 1 / 1;
    border: 2px solid transparent;
    border-radius: 0.75rem;
    padding: 0.35rem;
    background: #f7f7fb;
    cursor: pointer;
    transition: border-color 180ms ease, background-color 180ms ease;
  }
  .gallery__thumb:hover { background: #eef0fa; }
  .gallery__thumb.is-active {
    border-color: var(--color-brand-navy);
    background: var(--color-brand-white);
  }
  .gallery__thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
</style>

<script>
  const gallery = document.querySelector<HTMLElement>("[data-gallery]");
  if (gallery) {
    const main = gallery.querySelector<HTMLImageElement>("[data-gallery-main]")!;
    const thumbs = gallery.querySelectorAll<HTMLButtonElement>("[data-gallery-thumb]");

    thumbs.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        const src = thumb.dataset.src;
        const alt = thumb.dataset.alt ?? "";
        if (!src) return;
        // Cross-fade for a subtle polish
        main.style.opacity = "0.4";
        const img = new Image();
        img.onload = () => {
          main.src = src;
          main.alt = alt;
          main.style.opacity = "1";
        };
        img.src = src;

        thumbs.forEach((t) => {
          t.classList.remove("is-active");
          t.setAttribute("aria-selected", "false");
        });
        thumb.classList.add("is-active");
        thumb.setAttribute("aria-selected", "true");
      });
    });
  }
</script>
