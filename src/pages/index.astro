---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProductCard from "~/components/ProductCard.astro";
import ArrowRight from "@lucide/astro/icons/arrow-right";
import Truck from "@lucide/astro/icons/truck";
import CreditCard from "@lucide/astro/icons/credit-card";
import MessageCircle from "@lucide/astro/icons/message-circle";
import Star from "@lucide/astro/icons/star";
import Mail from "@lucide/astro/icons/mail";
import Clock from "@lucide/astro/icons/clock";
import googleReviews from "~/data/google-reviews.json";

const products = await getCollection("products");
const prTrackersAll = products
  .filter((p) => p.data.category === "pr-trackers")
  .sort((a, b) => a.data.priority - b.data.priority);
// Home carousel loop order (Bench Press ← Deadlift → My PR Set → Power Rack → …).
// Deadlift is index 1 so it lands centred on load; Bench Press peeks to the
// left, My PR Set peeks to the right.
const carouselOrder = [
  "bench-press-set",
  "deadlift-set",
  "my-pr-set",
  "power-rack-set",
] as const;
const prTrackers = carouselOrder.map(
  (slug) => prTrackersAll.find((p) => p.data.slug === slug)!,
);
const anilhas = products.find((p) => p.data.slug === "anilhas")!;
const camisetas = products
  .filter((p) => p.data.category === "camisetas")
  .sort((a, b) => a.data.priority - b.data.priority);

const SITE_URL = (import.meta.env.PUBLIC_SITE_URL ?? "https://prtracker.com.br").replace(/\/$/, "");

/** Live Google Business reviews snapshot — refreshed on each build via
 * scripts/fetch-google-reviews.mjs. Falls back to whatever was committed
 * if the build env is missing GOOGLE_PLACES_API_KEY. */
const testimonials = googleReviews.reviews.map((r) => ({
  name: r.author,
  when: r.relativeTime,
  rating: r.rating,
  text: r.text,
  photoUri: r.photoUri,
  googleUri: r.googleUri,
}));

const orgLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "PR Tracker",
  url: SITE_URL,
  logo: `${SITE_URL}/favicon.svg`,
  contactPoint: {
    "@type": "ContactPoint",
    telephone: "+55-51-98206-1914",
    contactType: "customer service",
    areaServed: "BR",
    availableLanguage: ["Portuguese"],
  },
  sameAs: ["https://instagram.com/pr.tracker"],
};

// Attach AggregateRating + top reviews so Google may surface star rich
// results. Only emitted when we actually have data from the snapshot.
if (googleReviews.rating && googleReviews.userRatingCount) {
  orgLd.aggregateRating = {
    "@type": "AggregateRating",
    ratingValue: googleReviews.rating,
    reviewCount: googleReviews.userRatingCount,
    bestRating: 5,
    worstRating: 1,
  };
  if (googleReviews.reviews.length > 0) {
    orgLd.review = googleReviews.reviews.slice(0, 5).map((r) => ({
      "@type": "Review",
      author: { "@type": "Person", name: r.author },
      reviewRating: {
        "@type": "Rating",
        ratingValue: r.rating,
        bestRating: 5,
        worstRating: 1,
      },
      reviewBody: r.text,
      datePublished: r.publishTime ?? undefined,
    }));
  }
}

const jsonLd = [
  orgLd,
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "PR Tracker",
    url: SITE_URL,
    inLanguage: "pt-BR",
    potentialAction: {
      "@type": "SearchAction",
      target: `${SITE_URL}/?q={search_term_string}`,
      "query-input": "required name=search_term_string",
    },
  },
];
---

<BaseLayout
  title="PR Tracker — Seu PR merece mais do que uma foto"
  description="Miniaturas-troféu premium feitas sob medida para celebrar seus PRs de CrossFit, powerlifting e halterofilismo. Configure a barra, escolha o exercício, receba seu troféu."
  jsonLd={jsonLd}
  preloadHeroHome
>
  <!-- ========================= HERO ========================= -->
  <section class="hero">
    <picture class="hero__bg" aria-hidden="true">
      {/* Desktop sources — browser picks the first supported format */}
      <source media="(min-width: 900px)" type="image/avif" srcset="/images/brand/hero-desktop.avif" />
      <source media="(min-width: 900px)" type="image/webp" srcset="/images/brand/hero-desktop.webp" />
      <source media="(min-width: 900px)" srcset="/images/brand/hero-desktop.jpg" />
      {/* Mobile sources */}
      <source type="image/avif" srcset="/images/brand/hero-mobile.avif" />
      <source type="image/webp" srcset="/images/brand/hero-mobile.webp" />
      <img
        src="/images/brand/hero-mobile.jpg"
        alt=""
        width="1080"
        height="1349"
        fetchpriority="high"
        loading="eager"
        decoding="async"
      />
    </picture>
    <div class="hero__scrim" aria-hidden="true"></div>

    <div class="container-page hero__inner">
      <div class="hero__content">
        <h1 class="hero__title">
          SEU PR<br />
          VIROU <span class="hero__title-accent">TROFÉU!</span>
        </h1>
        <p class="hero__subtitle">
          Miniaturas-troféu sob medida. Configure a barra, escolha o exercício
          e receba em casa a peça que conta sua história no treino.
        </p>
        <div class="hero__cta">
          <a href="#produtos" class="btn btn-primary btn-lg">
            <span>Comprar agora</span>
            <ArrowRight size={18} aria-hidden="true" />
          </a>
          <a href="#como-funciona" class="btn btn-ghost-on-dark">
            Como funciona
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================= PRODUTOS ========================= -->
  <section id="produtos" class="section section--paper">
    <div class="container-page">
      <div class="section__head">
        <h2>Miniaturas que guardam sua história</h2>
        <p>Cada set é uma réplica fiel do equipamento. Você configura, nós produzimos, você expõe.</p>
      </div>

      <div class="carousel product-carousel" data-carousel data-carousel-loop data-carousel-default="1">
        <button type="button" class="carousel__nav carousel__nav--prev" aria-label="Produto anterior" data-carousel-prev>
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button type="button" class="carousel__nav carousel__nav--next" aria-label="Próximo produto" data-carousel-next>
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </button>

        <div class="carousel__viewport" data-carousel-viewport>
          <div class="carousel__track">
            {prTrackers.map((p, i) => (
              <div class="pc-slide">
                <ProductCard product={p} eager={i < 2} />
              </div>
            ))}
          </div>
        </div>

        <div class="carousel__dots" role="tablist" aria-label="Navegação de produtos" data-carousel-dots></div>
      </div>
    </div>
  </section>

  <!-- ========================= DEPOIMENTOS ========================= -->
  <section class="section section--light testimonials">
    <div class="container-page">
      <div class="section__head testimonials__head">
        <h2>Troféu de quem vive o treino<br />dentro e fora da academia</h2>
        {googleReviews.rating && googleReviews.userRatingCount > 0 && (
          <div class="testimonials__rating">
            <strong class="testimonials__rating-value">{googleReviews.rating.toFixed(1)}</strong>
            <span class="testimonials__rating-stars" aria-label={`${googleReviews.rating} de 5 estrelas`}>
              {Array.from({ length: 5 }).map((_, i) => (
                <Star
                  size={18}
                  fill={i < Math.round(googleReviews.rating as number) ? "#FFC72C" : "transparent"}
                  color="#FFC72C"
                  aria-hidden="true"
                />
              ))}
            </span>
            <span class="testimonials__rating-count">
              {googleReviews.userRatingCount} avaliações no Google
            </span>
          </div>
        )}
        <a
          href={googleReviews.googleMapsUri ?? "https://www.google.com/search?q=PR+Tracker+avalia%C3%A7%C3%B5es"}
          target="_blank"
          rel="noopener noreferrer"
          class="testimonials__google"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.99.66-2.25 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <span>Ver no Google</span>
          <ArrowRight size={16} aria-hidden="true" />
        </a>
      </div>

      <div class="carousel" data-carousel>
        <button
          type="button"
          class="carousel__nav carousel__nav--prev"
          aria-label="Depoimento anterior"
          data-carousel-prev
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m15 18-6-6 6-6"/>
          </svg>
        </button>
        <button
          type="button"
          class="carousel__nav carousel__nav--next"
          aria-label="Próximo depoimento"
          data-carousel-next
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </button>

        <div class="carousel__viewport" data-carousel-viewport>
          <div class="carousel__track">
            {testimonials.map((t) => (
              <article class="testimonial">
                <div class="testimonial__head">
                  {t.photoUri ? (
                    <img
                      class="testimonial__avatar testimonial__avatar--photo"
                      src={t.photoUri}
                      alt=""
                      loading="lazy"
                      referrerpolicy="no-referrer"
                      width="44"
                      height="44"
                    />
                  ) : (
                    <div class="testimonial__avatar" aria-hidden="true">{t.name.charAt(0)}</div>
                  )}
                  <div>
                    <p class="testimonial__name">{t.name}</p>
                    <p class="testimonial__when">{t.when}</p>
                  </div>
                  <svg class="testimonial__g" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.99.66-2.25 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                  </svg>
                </div>
                <div class="testimonial__stars" aria-label={`${t.rating} de 5 estrelas`}>
                  {Array.from({ length: t.rating }).map(() => (
                    <Star size={16} fill="#FFC72C" color="#FFC72C" aria-hidden="true" />
                  ))}
                </div>
                <p class="testimonial__text">{t.text}</p>
              </article>
            ))}
          </div>
        </div>

        <div class="carousel__dots" role="tablist" aria-label="Navegação de depoimentos" data-carousel-dots></div>
      </div>
    </div>
  </section>

  <!-- ========================= COMO FUNCIONA ========================= -->
  <section id="como-funciona" class="section section--navy">
    <div class="container-page">
      <div class="section__head section__head--on-dark">
        <h2>Em 3 passos seu PR vira troféu</h2>
      </div>
      <ol class="steps">
        <li class="step">
          <span class="step__num">1</span>
          <h3 class="step__title">Escolha o set</h3>
          <p class="step__desc">Power Rack, Bench Press, Deadlift ou My PR Set com 20 exercícios — cada um uma miniatura fiel do equipamento real.</p>
        </li>
        <li class="step">
          <span class="step__num">2</span>
          <h3 class="step__title">Monte sua barra</h3>
          <p class="step__desc">Adicione anilhas no padrão olímpico IWF. A barra atualiza em tempo real no configurador.</p>
        </li>
        <li class="step">
          <span class="step__num">3</span>
          <h3 class="step__title">Receba em casa</h3>
          <p class="step__desc">Produção sob demanda, envio para todo o Brasil com rastreio. Seu PR, feito troféu.</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========================= ANILHAS BANNER ========================= -->
  <section class="section section--light">
    <div class="container-page banner banner--lime">
      <div class="banner__text">
        <p class="banner__eyebrow">Bateu PR?</p>
        <h2 class="banner__title">Atualize seu troféu com novos pares de anilhas.</h2>
        <p class="banner__sub">Mesmo padrão olímpico, mesmo encaixe. A partir de R$ 10,00 o par.</p>
        <a href={`/product/${anilhas.data.slug}`} class="btn btn-secondary mt-5">
          <span>Ver anilhas avulsas</span>
          <ArrowRight size={18} aria-hidden="true" />
        </a>
      </div>
      <div class="banner__media">
        <picture>
          <source type="image/avif" srcset="/images/products/anilhas/Anilhas_0007_todas-anilhas-clean.avif" />
          <source type="image/webp" srcset="/images/products/anilhas/Anilhas_0007_todas-anilhas-clean.webp" />
          <img
            src="/images/products/anilhas/Anilhas_0007_todas-anilhas-clean.jpg"
            alt={anilhas.data.images[0]!.alt}
            width="600"
            height="600"
            loading="lazy"
            decoding="async"
          />
        </picture>
      </div>
    </div>
  </section>

  <!-- ========================= CAMISETAS ========================= -->
  <section class="section section--light">
    <div class="container-page">
      <div class="section__head">
        <h2>Veste o box</h2>
        <p>Camisetas PR Tracker — para os treinos mais pesados.</p>
      </div>

      <div class="carousel product-carousel product-carousel--2" data-carousel data-carousel-loop>
        <button type="button" class="carousel__nav carousel__nav--prev" aria-label="Camiseta anterior" data-carousel-prev>
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button type="button" class="carousel__nav carousel__nav--next" aria-label="Próxima camiseta" data-carousel-next>
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </button>

        <div class="carousel__viewport" data-carousel-viewport>
          <div class="carousel__track">
            {camisetas.map((p) => (
              <div class="pc-slide">
                <ProductCard product={p} />
              </div>
            ))}
          </div>
        </div>

        <div class="carousel__dots" role="tablist" aria-label="Navegação de camisetas" data-carousel-dots></div>
      </div>

      <div class="text-center mt-10">
        <a href="/product-category/camisetas" class="btn btn-outline">
          Ver todas
          <ArrowRight size={18} aria-hidden="true" />
        </a>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll<HTMLElement>("[data-carousel]").forEach((root) => {
      const viewport = root.querySelector<HTMLElement>("[data-carousel-viewport]");
      const prevBtn = root.querySelector<HTMLButtonElement>("[data-carousel-prev]");
      const nextBtn = root.querySelector<HTMLButtonElement>("[data-carousel-next]");
      const dotsBox = root.querySelector<HTMLElement>("[data-carousel-dots]");
      if (!viewport) return;

      const slides = Array.from(viewport.querySelectorAll<HTMLElement>(":scope > .carousel__track > *"));
      if (slides.length === 0) return;
      const loop = root.hasAttribute("data-carousel-loop");

      const current = () => {
        const x = viewport.scrollLeft + viewport.clientWidth / 2;
        let best = 0, bestDist = Infinity;
        slides.forEach((s, i) => {
          const center = s.offsetLeft + s.clientWidth / 2 - viewport.offsetLeft;
          const dist = Math.abs(center - x);
          if (dist < bestDist) { bestDist = dist; best = i; }
        });
        return best;
      };

      const scrollPositionFor = (slide: HTMLElement) =>
        slide.offsetLeft - viewport.offsetLeft - (viewport.clientWidth - slide.clientWidth) / 2;

      const scrollToIdx = (i: number, behavior: ScrollBehavior = "smooth") => {
        const len = slides.length;
        const idx = loop ? ((i % len) + len) % len : Math.max(0, Math.min(len - 1, i));
        const slide = slides[idx];
        if (slide) viewport.scrollTo({ left: scrollPositionFor(slide), behavior });
      };

      if (dotsBox) {
        slides.forEach((_, i) => {
          const dot = document.createElement("button");
          dot.type = "button";
          dot.className = "carousel__dot";
          dot.setAttribute("role", "tab");
          dot.setAttribute("aria-label", `Slide ${i + 1}`);
          dot.addEventListener("click", () => scrollToIdx(i));
          dotsBox.appendChild(dot);
        });
      }

      const update = () => {
        if (!dotsBox) return;
        const i = current();
        dotsBox.querySelectorAll<HTMLElement>(".carousel__dot").forEach((dot, idx) => {
          dot.setAttribute("aria-selected", idx === i ? "true" : "false");
        });
      };

      prevBtn?.addEventListener("click", () => scrollToIdx(current() - 1));
      nextBtn?.addEventListener("click", () => scrollToIdx(current() + 1));
      viewport.addEventListener("scroll", () => requestAnimationFrame(update), { passive: true });

      // Default slide index (from data-carousel-default) — centred on load.
      const defaultIdx = Number(root.dataset.carouselDefault ?? "0") || 0;
      const recenter = () => scrollToIdx(current(), "auto");
      requestAnimationFrame(() => scrollToIdx(defaultIdx, "auto"));
      window.addEventListener("resize", recenter, { passive: true });
      update();
    });
  </script>

  <!-- ========================= PARCERIAS ========================= -->
  <section id="parcerias" class="section section--navy parcerias">
    <div class="container-page parcerias__grid">
      <div>
        <p class="eyebrow eyebrow--lime">Parcerias</p>
        <h2 class="text-brand-white">Para boxes, academias e eventos</h2>
        <p class="parcerias__lead">
          Se você organiza um evento esportivo, quer presentear atletas ou criar algo
          exclusivo para sua marca, a PR Tracker pode ajudar. Fale com a gente para
          descontos em volume, personalização e produtos exclusivos.
        </p>
        <a href="#contato" class="btn btn-primary mt-4">
          Falar com a gente
          <ArrowRight size={18} aria-hidden="true" />
        </a>
      </div>
      <ul class="parcerias__bullets">
        <li>Descontos progressivos em pedidos em volume</li>
        <li>Personalização com a sua marca</li>
        <li>Produtos exclusivos para eventos e premiação</li>
        <li>Comissão para coaches e donos de box</li>
      </ul>
    </div>
  </section>

  <!-- ========================= CONTATO (home) ========================= -->
  <section id="contato" class="section section--light contact-home">
    <div class="container-page contact-home__grid">
      <div class="contact-home__copy">
        <p class="contact-home__eyebrow">Fale com a gente</p>
        <h2 class="contact-home__title">Estamos por aqui<br />para qualquer dúvida.</h2>
        <p class="contact-home__lead">
          Pedidos, prazos, trocas, parceria com box ou creator — mande mensagem.
          Respondemos em dias úteis, 8h às 18h.
        </p>

        <ul class="contact-home__links">
          <li>
            <a href="https://wa.me/5551982061914" target="_blank" rel="noopener noreferrer" class="contact-home__link">
              <span class="contact-home__link-icon">
