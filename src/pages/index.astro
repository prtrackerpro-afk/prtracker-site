---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProductCard from "~/components/ProductCard.astro";
import ArrowRight from "@lucide/astro/icons/arrow-right";
import ArrowDown from "@lucide/astro/icons/arrow-down";

const products = await getCollection("products");
const prTrackers = products
  .filter((p) => p.data.category === "pr-trackers")
  .sort((a, b) => a.data.priority - b.data.priority);
const anilhas = products.find((p) => p.data.slug === "anilhas")!;
const camisetas = products
  .filter((p) => p.data.category === "camisetas")
  .sort((a, b) => a.data.priority - b.data.priority);

const SITE_URL = (import.meta.env.PUBLIC_SITE_URL ?? "https://prtracker.com.br").replace(/\/$/, "");

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "PR Tracker",
    url: SITE_URL,
    logo: `${SITE_URL}/favicon.svg`,
    contactPoint: {
      "@type": "ContactPoint",
      telephone: "+55-51-98206-1914",
      contactType: "customer service",
      areaServed: "BR",
      availableLanguage: ["Portuguese"],
    },
    sameAs: ["https://instagram.com/pr.tracker"],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "PR Tracker",
    url: SITE_URL,
    inLanguage: "pt-BR",
    potentialAction: {
      "@type": "SearchAction",
      target: `${SITE_URL}/?q={search_term_string}`,
      "query-input": "required name=search_term_string",
    },
  },
];
---

<BaseLayout
  title="PR Tracker — Seu PR merece mais do que uma foto"
  description="Miniaturas-troféu premium feitas sob medida para celebrar seus PRs de CrossFit, powerlifting e halterofilismo. Configure a barra, escolha o exercício, receba seu troféu."
  transparentHeader
  jsonLd={jsonLd}
>
  <!-- ========================= HERO ========================= -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true"></div>

    <div class="hero__frame container-page">
      <!-- Top meta rail -->
      <div class="hero__rail">
        <span class="mono-label mono-label--lime">// VOL·04 · EDIÇÃO 2026</span>
        <span class="hero__rail-dot"></span>
        <span class="mono-label" style="color: rgb(255 255 255 / 0.55)">BRASIL · PRODUÇÃO SOB DEMANDA</span>
      </div>

      <div class="hero__grid">
        <!-- Left: copy block -->
        <div class="hero__copy">
          <h1 class="hero__title">
            SEU PR<br />
            MERECE MAIS<br />
            <span class="hero__title-accent">DO QUE</span><br />
            UMA FOTO<span class="hero__title-period">.</span>
          </h1>

          <p class="hero__subtitle">
            Miniaturas-troféu sob medida. Você configura a barra, escolhe o
            exercício e recebe a peça que conta a sua história no treino.
          </p>

          <div class="hero__cta">
            <a href="#produtos" class="btn btn-primary btn-lg">
              <span>MONTE SEU TROFÉU</span>
              <ArrowRight size={18} aria-hidden="true" />
            </a>
            <a href="#processo" class="btn btn-ghost-on-dark">
              <ArrowDown size={16} aria-hidden="true" />
              <span>PROCESSO</span>
            </a>
          </div>
        </div>

        <!-- Right: product visual with measurement overlay -->
        <div class="hero__visual">
          <!-- Corner tickmarks -->
          <span class="tick tick--tl" aria-hidden="true"></span>
          <span class="tick tick--tr" aria-hidden="true"></span>
          <span class="tick tick--bl" aria-hidden="true"></span>
          <span class="tick tick--br" aria-hidden="true"></span>

          <img
            src="/images/products/power-rack-set/Power-Rack-base-diagonal.jpeg"
            alt="Power Rack Set — miniatura-troféu PR Tracker"
            width="800"
            height="800"
            fetchpriority="high"
            loading="eager"
            decoding="async"
            class="hero__visual-img"
          />

          <!-- Bottom measurement strip -->
          <div class="hero__visual-meta" aria-hidden="true">
            <span>H · 150 MM</span>
            <span>AL 100%</span>
            <span>NO.01/07</span>
          </div>
        </div>
      </div>

      <!-- Bottom marquee of trust/product lineup -->
      <div class="hero__marquee" aria-hidden="true">
        <span>POWER·RACK</span>
        <span class="sep">/</span>
        <span>BENCH·PRESS</span>
        <span class="sep">/</span>
        <span>DEADLIFT</span>
        <span class="sep">/</span>
        <span>MY·PR — 20 EXERCÍCIOS</span>
        <span class="sep">/</span>
        <span>ANILHAS OLÍMPICAS IWF</span>
        <span class="sep">/</span>
        <span>PIX · 5% OFF</span>
      </div>
    </div>
  </section>

  <!-- ========================= PRODUTOS ========================= -->
  <section id="produtos" class="section section--light">
    <div class="container-page">
      <div class="section__head">
        <span class="mono-label">// CATÁLOGO / 01</span>
        <h2 class="section__title">Cada set<br />é um troféu<br />diferente.</h2>
        <p class="section__lead">
          Quatro linhas de miniaturas, cada uma uma réplica fiel do equipamento real.
          Configure a sua barra, escolha o exercício, receba.
        </p>
      </div>

      <div class="product-grid">
        {prTrackers.map((p, i) => (
          <ProductCard product={p} eager={i < 2} index={i} />
        ))}
      </div>
    </div>
  </section>

  <!-- ========================= PROCESSO ========================= -->
  <section id="processo" class="section section--navy processo">
    <div class="container-page">
      <div class="section__head section__head--on-dark">
        <span class="mono-label mono-label--lime">// PROCESSO / 02</span>
        <h2 class="section__title">Em 3 passos,<br />seu PR vira troféu.</h2>
      </div>

      <ol class="steps">
        <li class="step">
          <div class="step__num-wrap">
            <span class="step__num">01</span>
            <span class="step__label mono-label mono-label--lime">ESCOLHA</span>
          </div>
          <div class="step__body">
            <h3 class="step__title">Selecione o set</h3>
            <p class="step__desc">
              Power Rack, Bench Press, Deadlift ou My PR Set — 20 exercícios
              de força para escolher. Cada um é uma miniatura fiel do equipamento real.
            </p>
          </div>
        </li>
        <li class="step">
          <div class="step__num-wrap">
            <span class="step__num">02</span>
            <span class="step__label mono-label mono-label--lime">MONTE</span>
          </div>
          <div class="step__body">
            <h3 class="step__title">Configure a barra</h3>
            <p class="step__desc">
              Adicione anilhas no padrão olímpico IWF. A barra atualiza em
              tempo real — peso total, preço e ocupação.
            </p>
          </div>
        </li>
        <li class="step">
          <div class="step__num-wrap">
            <span class="step__num">03</span>
            <span class="step__label mono-label mono-label--lime">RECEBA</span>
          </div>
          <div class="step__body">
            <h3 class="step__title">Troféu em casa</h3>
            <p class="step__desc">
              Produção sob demanda, envio para todo o Brasil com rastreio.
              Seu PR, feito troféu.
            </p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========================= ANILHAS BANNER ========================= -->
  <section class="section section--paper">
    <div class="container-page">
      <div class="anilhas-banner">
        <div class="anilhas-banner__content">
          <span class="mono-label">// UPGRADE / 03</span>
          <h2 class="anilhas-banner__title">Bateu PR?<br />Atualize seu troféu.</h2>
          <p class="anilhas-banner__sub">
            Pares de anilhas avulsas no mesmo encaixe. Padrão olímpico,
            cores oficiais, preço único.
          </p>
          <a href={`/product/${anilhas.data.slug}`} class="btn btn-secondary">
            <span>Ver anilhas avulsas</span>
            <ArrowRight size={18} aria-hidden="true" />
          </a>
        </div>
        <div class="anilhas-banner__media">
          <img
            src={anilhas.data.images[0]!.src}
            alt={anilhas.data.images[0]!.alt}
            width="600"
            height="600"
            loading="lazy"
            decoding="async"
          />
          <div class="plate-chips" aria-hidden="true">
            <span class="plate-chip" style="background: var(--color-plate-25)">25</span>
            <span class="plate-chip" style="background: var(--color-plate-20)">20</span>
            <span class="plate-chip" style="background: var(--color-plate-15); color: #01002A">15</span>
            <span class="plate-chip" style="background: var(--color-plate-10)">10</span>
            <span class="plate-chip" style="background: var(--color-plate-5)">5</span>
            <span class="plate-chip" style="background: var(--color-plate-2-5)">2.5</span>
            <span class="plate-chip" style="background: var(--color-plate-1-25); color: #01002A">1.25</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================= CAMISETAS ========================= -->
  <section class="section section--light">
    <div class="container-page">
      <div class="section__head section__head--split">
        <div>
          <span class="mono-label">// VESTUÁRIO / 04</span>
          <h2 class="section__title">Veste o box.</h2>
        </div>
        <a href="/product-category/camisetas" class="btn btn-outline">
          <span>VER TODAS</span>
          <ArrowRight size={18} aria-hidden="true" />
        </a>
      </div>
      <div class="product-grid product-grid--2">
        {camisetas.map((p, i) => <ProductCard product={p} index={i} />)}
      </div>
    </div>
  </section>

  <!-- ========================= SOBRE ========================= -->
  <section class="section section--paper about">
    <div class="container-page about__grid">
      <div class="about__lead">
        <span class="mono-label">// MANIFESTO / 05</span>
        <h2 class="about__title">
          Não é souvenir.<br />
          Não é brinquedo.<br />
          <span class="about__title-accent">É troféu.</span>
        </h2>
      </div>

      <div class="about__body">
        <p>
          Primeira marca brasileira de miniaturas premium no universo da força.
          Cada peça é produzida sob demanda com barra em aço inoxidável usinado,
          anilhas em plástico de alta densidade no padrão olímpico IWF, e base
          específica por produto.
        </p>
        <p>
          A PR Tracker nasceu pra celebrar quem treina de verdade. Cada PR
          merece mais do que uma foto na galeria do celular.
        </p>

        <dl class="about__stats">
          <div class="stat">
            <dt class="mono-label mono-label--dim">EXERCÍCIOS</dt>
            <dd class="stat__value">20</dd>
            <dd class="stat__sub">no My PR Set</dd>
          </div>
          <div class="stat">
            <dt class="mono-label mono-label--dim">PESOS</dt>
            <dd class="stat__value">07</dd>
            <dd class="stat__sub">anilhas olímpicas</dd>
          </div>
          <div class="stat">
            <dt class="mono-label mono-label--dim">BRASIL</dt>
            <dd class="stat__value">100%</dd>
            <dd class="stat__sub">produzido aqui</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <!-- ========================= FINAL CTA ========================= -->
  <section class="section section--navy final-cta">
    <div class="container-page final-cta__inner">
      <span class="mono-label mono-label--lime">// CTA / 06</span>
      <h2 class="final-cta__title">
        Seu próximo PR<br />
        <span class="final-cta__title-accent">já tem troféu.</span>
      </h2>
      <p class="final-cta__sub">
        Monte o seu no configurador. Pix com 5% OFF. Envio para todo o Brasil.
      </p>
      <a href="#produtos" class="btn btn-primary btn-lg">
        <span>COMEÇAR AGORA</span>
        <ArrowRight size={18} aria-hidden="true" />
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ======================= HERO ======================= */
  .hero {
    position: relative;
    color: var(--color-brand-white);
    background: var(--color-brand-navy);
    overflow: hidden;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(rgb(216 255 44 / 0.08) 1px, transparent 1px),
      linear-gradient(180deg, rgb(216 255 44 / 0) 0%, rgb(216 255 44 / 0.03) 100%);
    background-size: 32px 32px, 100% 100%;
    pointer-events: none;
  }
  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 78% 40%, rgb(216 255 44 / 0.06), transparent 55%);
    pointer-events: none;
  }

  .hero__frame {
    position: relative;
    z-index: 1;
    padding-top: clamp(5rem, 10vh, 8rem);
    padding-bottom: 0;
  }

  .hero__rail {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px dashed rgb(255 255 255 / 0.15);
    margin-bottom: 3rem;
  }
  .hero__rail-dot {
    width: 6px;
    height: 6px;
    background: var(--color-brand-lime);
    border-radius: 9999px;
  }

  .hero__grid {
    display: grid;
    gap: 3rem;
    align-items: end;
  }
  @media (min-width: 960px) {
    .hero__grid {
      grid-template-columns: 1.25fr 1fr;
      gap: 4rem;
    }
  }

  /* Headline — the money shot */
  .hero__title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(3.25rem, 10vw + 0.5rem, 10rem);
    line-height: 0.88;
    letter-spacing: -0.035em;
    text-transform: uppercase;
    color: var(--color-brand-white);
    margin: 0;
  }
  .hero__title-accent {
    color: var(--color-brand-lime);
    font-style: italic;
  }
  .hero__title-period { color: var(--color-brand-lime); }

  .hero__subtitle {
    max-width: 34rem;
    margin: 2rem 0 2.5rem;
    color: rgb(255 255 255 / 0.72);
    font-size: clamp(1rem, 0.8vw + 0.75rem, 1.125rem);
    line-height: 1.55;
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-bottom: 3rem;
  }

  /* Visual */
  .hero__visual {
    position: relative;
    padding: clamp(1rem, 4vw, 2.5rem);
    aspect-ratio: 1 / 1;
    max-width: 520px;
    margin-left: auto;
    border: 1px solid rgb(255 255 255 / 0.08);
    background:
      radial-gradient(circle at center, rgb(216 255 44 / 0.04), transparent 70%),
      linear-gradient(135deg, rgb(255 255 255 / 0.02), transparent);
  }
  .hero__visual-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 30px 60px rgb(0 0 0 / 0.5));
    animation: float 6s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__visual-img { animation: none; }
  }

  /* Corner tickmarks */
  .tick {
    position: absolute;
    width: 14px;
    height: 14px;
    color: var(--color-brand-lime);
  }
  .tick::before, .tick::after {
    content: "";
    position: absolute;
    background: currentColor;
  }
  .tick::before { width: 14px; height: 1px; }
  .tick::after  { width: 1px; height: 14px; }
  .tick--tl { top: 0; left: 0; }
  .tick--tl::before { top: 0; left: 0; }
  .tick--tl::after  { top: 0; left: 0; }
  .tick--tr { top: 0; right: 0; }
  .tick--tr::before { top: 0; right: 0; }
  .tick--tr::after  { top: 0; right: 0; }
  .tick--bl { bottom: 0; left: 0; }
  .tick--bl::before { bottom: 0; left: 0; }
  .tick--bl::after  { bottom: 0; left: 0; }
  .tick--br { bottom: 0; right: 0; }
  .tick--br::before { bottom: 0; right: 0; }
  .tick--br::after  { bottom: 0; right: 0; }

  .hero__visual-meta {
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: -1.5rem;
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.4rem 0.75rem;
    background: var(--color-brand-navy);
    color: var(--color-brand-lime);
    border: 1px solid rgb(216 255 44 / 0.3);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* Marquee strip */
  .hero__marquee {
    margin-top: 4rem;
    padding-block: 1.25rem;
    border-top: 1px solid rgb(255 255 255 / 0.1);
    border-bottom: 1px solid rgb(255 255 255 / 0.1);
    display: flex;
    align-items: center;
    gap: 1.25rem;
    overflow-x: auto;
    white-space: nowrap;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.85);
    scrollbar-width: none;
  }
  .hero__marquee::-webkit-scrollbar { display: none; }
  .hero__marquee .sep { color: var(--color-brand-lime); font-weight: 400; }

  /* ======================= SECTIONS ======================= */
  .section {
    padding: clamp(4rem, 8vw, 7rem) 0;
    position: relative;
  }
  .section--light { background: var(--color-brand-white); color: var(--color-brand-navy); }
  .section--navy  { background: var(--color-brand-navy); color: var(--color-brand-white); }
  .section--paper { background: var(--color-paper); color: var(--color-brand-navy); }

  .section__head {
    margin-bottom: 3rem;
    max-width: 58rem;
  }
  .section__head .mono-label { margin-bottom: 1rem; display: block; }
  .section__title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(2rem, 4vw + 1rem, 4.25rem);
    line-height: 0.9;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin: 0;
  }
  .section__lead {
    margin-top: 1.25rem;
    max-width: 40rem;
    font-size: clamp(1rem, 0.5vw + 0.8rem, 1.15rem);
    color: var(--color-brand-gray);
    line-height: 1.55;
  }
  .section__head--on-dark .section__title { color: var(--color-brand-white); }
  .section__head--split {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: flex-end;
    justify-content: space-between;
  }

  /* ======================= PRODUCT GRID ======================= */
  .product-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
  }
  .product-grid--2 {
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    max-width: 52rem;
  }

  /* ======================= PROCESSO / STEPS ======================= */
  .processo { border-top: 1px solid rgb(216 255 44 / 0.2); }
  .steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .steps { grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  }
  .step {
    position: relative;
    padding: 2rem 0 0;
    border-top: 2px solid var(--color-brand-lime);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .step__num-wrap {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .step__num {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(4rem, 6vw, 6rem);
    line-height: 0.85;
    color: var(--color-brand-white);
    letter-spacing: -0.03em;
  }
  .step__body { display: flex; flex-direction: column; gap: 0.5rem; }
  .step__title {
    font-size: 1.5rem;
    margin: 0;
    color: var(--color-brand-white);
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }
  .step__desc {
    color: rgb(255 255 255 / 0.7);
    margin: 0;
    line-height: 1.55;
    max-width: 36ch;
  }

  /* ======================= ANILHAS BANNER ======================= */
  .anilhas-banner {
    display: grid;
    align-items: center;
    gap: 2.5rem;
    padding: 2.5rem;
    background: var(--color-brand-white);
    border: 1px solid rgb(1 0 42 / 0.12);
    position: relative;
  }
  .anilhas-banner::before {
    content: "";
    position: absolute;
    inset: 0;
    border: 1px solid var(--color-brand-navy);
    transform: translate(8px, 8px);
    z-index: -1;
    pointer-events: none;
  }
  @media (min-width: 720px) {
    .anilhas-banner {
      grid-template-columns: 1.1fr 1fr;
      padding: 3.5rem 3.5rem;
    }
  }
  .anilhas-banner__content .mono-label { display: block; margin-bottom: 1rem; }
  .anilhas-banner__title {
    font-size: clamp(2rem, 3vw + 1rem, 3.25rem);
    margin: 0 0 1rem;
    line-height: 0.9;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }
  .anilhas-banner__sub {
    color: var(--color-brand-gray);
    margin: 0 0 1.75rem;
    font-size: 1.05rem;
    line-height: 1.55;
    max-width: 36ch;
  }
  .anilhas-banner__media {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: 1rem;
  }
  .anilhas-banner__media img {
    max-width: 320px;
    width: 100%;
    height: auto;
  }
  .plate-chips {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(2.5rem, 1fr));
    gap: 0.35rem;
    max-width: 180px;
  }
  .plate-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    color: #fff;
    font-family: var(--font-product);
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  /* ======================= ABOUT ======================= */
  .about__grid {
    display: grid;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 960px) {
    .about__grid { grid-template-columns: 1.1fr 1fr; gap: 5rem; }
  }
