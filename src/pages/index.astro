<script>
  // Show success toast when ?sent=true in URL (home contact form)
  const params = new URLSearchParams(window.location.search);
  if (params.get("sent") === "true") {
    const form = document.querySelector("#contactFormHome");
    if (form) {
      const banner = document.createElement("div");
      banner.className = "contact-home__sent";
      banner.setAttribute("role", "status");
      banner.textContent = "Mensagem enviada! Responderemos em até 1 dia útil.";
      form.parentElement?.insertBefore(banner, form);
      form.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  }
</script>
