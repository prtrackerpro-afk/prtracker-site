---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProductCard from "~/components/ProductCard.astro";
import ArrowRight from "@lucide/astro/icons/arrow-right";
import Truck from "@lucide/astro/icons/truck";
import CreditCard from "@lucide/astro/icons/credit-card";
import MessageCircle from "@lucide/astro/icons/message-circle";
import Star from "@lucide/astro/icons/star";

const products = await getCollection("products");
const prTrackers = products
  .filter((p) => p.data.category === "pr-trackers")
  .sort((a, b) => a.data.priority - b.data.priority);
const anilhas = products.find((p) => p.data.slug === "anilhas")!;
const camisetas = products
  .filter((p) => p.data.category === "camisetas")
  .sort((a, b) => a.data.priority - b.data.priority);

const SITE_URL = (import.meta.env.PUBLIC_SITE_URL ?? "https://prtracker.com.br").replace(/\/$/, "");

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "PR Tracker",
    url: SITE_URL,
    logo: `${SITE_URL}/favicon.svg`,
    contactPoint: {
      "@type": "ContactPoint",
      telephone: "+55-51-98206-1914",
      contactType: "customer service",
      areaServed: "BR",
      availableLanguage: ["Portuguese"],
    },
    sameAs: ["https://instagram.com/pr.tracker"],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "PR Tracker",
    url: SITE_URL,
    inLanguage: "pt-BR",
    potentialAction: {
      "@type": "SearchAction",
      target: `${SITE_URL}/?q={search_term_string}`,
      "query-input": "required name=search_term_string",
    },
  },
];

/** Static social-proof testimonials (copy from real reviews at prtracker.com.br). */
const testimonials = [
  {
    name: "Julia Maia Heckler",
    when: "3 meses atrás",
    rating: 5,
    text: "Produtos de ótima qualidade, fiquei surpreendida! E chegou antes do que era previsto.",
  },
  {
    name: "Matheus Oliveira",
    when: "3 meses atrás",
    rating: 5,
    text: "Altamente confiável. Produto bem feito e suporte rápido.",
  },
  {
    name: "Pietro Schaff",
    when: "3 meses atrás",
    rating: 5,
    text: "Qualidade do produto é impecável, atenção aos detalhes, principalmente nos acabamentos das anilhas!",
  },
];
---

<BaseLayout
  title="PR Tracker — Seu PR merece mais do que uma foto"
  description="Miniaturas-troféu premium feitas sob medida para celebrar seus PRs de CrossFit, powerlifting e halterofilismo. Configure a barra, escolha o exercício, receba seu troféu."
  jsonLd={jsonLd}
>
  <!-- ========================= HERO ========================= -->
  <section class="hero">
    <div class="container-page hero__inner">
      <div class="hero__visual">
        <img
          src="/images/products/power-rack-set/Power-Rack-base-diagonal.jpeg"
          alt="Power Rack Set — miniatura-troféu PR Tracker"
          width="800"
          height="800"
          fetchpriority="high"
          loading="eager"
          decoding="async"
        />
      </div>

      <div class="hero__copy">
        <h1 class="hero__title">
          SEU PR<br />
          VIROU <span class="hero__title-accent">TROFÉU!</span>
        </h1>
        <p class="hero__subtitle">
          Miniaturas-troféu sob medida. Configure a barra, escolha o exercício,
          receba em casa a peça que conta sua história no treino.
        </p>
        <div class="hero__cta">
          <a href="#produtos" class="btn btn-primary btn-lg">
            <span>Comprar agora</span>
            <ArrowRight size={18} aria-hidden="true" />
          </a>
          <a href="#como-funciona" class="btn btn-ghost-on-dark">
            Como funciona
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================= PRODUTOS ========================= -->
  <section id="produtos" class="section section--light">
    <div class="container-page">
      <div class="section__head">
        <h2>Miniaturas que guardam sua história</h2>
        <p>Cada set é uma réplica fiel do equipamento. Você configura, nós produzimos, você expõe.</p>
      </div>
      <div class="product-grid">
        {prTrackers.map((p, i) => (
          <ProductCard product={p} eager={i < 2} />
        ))}
      </div>
    </div>
  </section>

  <!-- ========================= COMO FUNCIONA ========================= -->
  <section id="como-funciona" class="section section--navy">
    <div class="container-page">
      <div class="section__head section__head--on-dark">
        <h2>Em 3 passos seu PR vira troféu</h2>
      </div>
      <ol class="steps">
        <li class="step">
          <span class="step__num">1</span>
          <h3 class="step__title">Escolha o set</h3>
          <p class="step__desc">Power Rack, Bench Press, Deadlift ou My PR Set com 20 exercícios — cada um uma miniatura fiel do equipamento real.</p>
        </li>
        <li class="step">
          <span class="step__num">2</span>
          <h3 class="step__title">Monte sua barra</h3>
          <p class="step__desc">Adicione anilhas no padrão olímpico IWF. A barra atualiza em tempo real no configurador.</p>
        </li>
        <li class="step">
          <span class="step__num">3</span>
          <h3 class="step__title">Receba em casa</h3>
          <p class="step__desc">Produção sob demanda, envio para todo o Brasil com rastreio. Seu PR, feito troféu.</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========================= ANILHAS BANNER ========================= -->
  <section class="section section--light">
    <div class="container-page banner banner--lime">
      <div class="banner__text">
        <p class="banner__eyebrow">Bateu PR?</p>
        <h2 class="banner__title">Atualize seu troféu com novos pares de anilhas.</h2>
        <p class="banner__sub">Mesmo padrão olímpico, mesmo encaixe. A partir de R$ 10,00 o par.</p>
        <a href={`/product/${anilhas.data.slug}`} class="btn btn-secondary mt-5">
          <span>Ver anilhas avulsas</span>
          <ArrowRight size={18} aria-hidden="true" />
        </a>
      </div>
      <div class="banner__media">
        <img
          src={anilhas.data.images[0]!.src}
          alt={anilhas.data.images[0]!.alt}
          width="600"
          height="600"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <!-- ========================= CAMISETAS ========================= -->
  <section class="section section--light">
    <div class="container-page">
      <div class="section__head">
        <h2>Veste o box</h2>
        <p>Camisetas PR Tracker — para os treinos mais pesados.</p>
      </div>
      <div class="product-grid product-grid--2">
        {camisetas.map((p) => <ProductCard product={p} />)}
      </div>
      <div class="text-center mt-10">
        <a href="/product-category/camisetas" class="btn btn-outline">
          Ver todas
          <ArrowRight size={18} aria-hidden="true" />
        </a>
      </div>
    </div>
  </section>

  <!-- ========================= DEPOIMENTOS ========================= -->
  <section class="section section--light testimonials">
    <div class="container-page">
      <div class="section__head">
        <h2>Troféu de quem vive o treino<br />dentro e fora da academia</h2>
      </div>
      <div class="testimonial-grid">
        {testimonials.map((t) => (
          <article class="testimonial">
            <div class="testimonial__head">
              <div class="testimonial__avatar" aria-hidden="true">
                {t.name.charAt(0)}
              </div>
              <div>
                <p class="testimonial__name">{t.name}</p>
                <p class="testimonial__when">{t.when}</p>
              </div>
            </div>
            <div class="testimonial__stars" aria-label={`${t.rating} de 5 estrelas`}>
              {Array.from({ length: t.rating }).map(() => (
                <Star size={16} fill="#FFC72C" color="#FFC72C" aria-hidden="true" />
              ))}
            </div>
            <p class="testimonial__text">{t.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ========================= FEATURES ========================= -->
  <section class="section section--light features-section">
    <div class="container-page">
      <div class="features">
        <div class="feature">
          <Truck size={32} strokeWidth={1.5} aria-hidden="true" />
          <h3>Envio &amp; Rastreio</h3>
          <p>Entrega rápida e rastreável para todo o Brasil.</p>
        </div>
        <div class="feature">
          <CreditCard size={32} strokeWidth={1.5} aria-hidden="true" />
          <h3>Pagamento Seguro</h3>
          <p>Pague com Pix e ganhe 5% de desconto, ou cartão em até 6×.</p>
        </div>
        <div class="feature">
          <MessageCircle size={32} strokeWidth={1.5} aria-hidden="true" />
          <h3>Suporte Humanizado</h3>
          <p>Atendimento rápido no WhatsApp e por e-mail.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================= PARCERIAS ========================= -->
  <section id="parcerias" class="section section--navy parcerias">
    <div class="container-page parcerias__grid">
      <div>
        <p class="eyebrow eyebrow--lime">Parcerias</p>
        <h2 class="text-brand-white">Para boxes, academias e eventos</h2>
        <p class="parcerias__lead">
          Se você organiza um evento esportivo, quer presentear atletas ou criar algo
          exclusivo para sua marca, a PR Tracker pode ajudar. Fale com a gente para
          descontos em volume, personalização e produtos exclusivos.
        </p>
        <a href="/contato" class="btn btn-primary mt-4">
          Falar com a gente
          <ArrowRight size={18} aria-hidden="true" />
        </a>
      </div>
      <ul class="parcerias__bullets">
        <li>Descontos progressivos em pedidos em volume</li>
        <li>Personalização com a sua marca</li>
        <li>Produtos exclusivos para eventos e premiação</li>
        <li>Comissão para coaches e donos de box</li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  /* ======================= HERO ======================= */
  .hero {
    position: relative;
    background: var(--color-brand-navy);
    color: var(--color-brand-white);
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 25% 50%, rgb(216 255 44 / 0.05) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 30%, rgb(216 255 44 / 0.04) 0%, transparent 55%);
    pointer-events: none;
  }
  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 2rem;
    align-items: center;
    padding-top: clamp(2rem, 5vw, 4rem);
    padding-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  @media (min-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }

  .hero__visual {
    display: flex;
    justify-content: center;
    order: 1;
  }
  .hero__visual img {
    width: 100%;
    max-width: 520px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 20px 50px rgb(0 0 0 / 0.5));
  }
  @media (min-width: 900px) {
    .hero__visual { order: 0; }
    .hero__visual img { max-width: 580px; }
  }

  .hero__copy {
    text-align: left;
    order: 2;
  }
  .hero__title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(2.75rem, 5.5vw + 1rem, 6rem);
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: var(--color-brand-white);
    margin: 0;
    text-transform: uppercase;
  }
  .hero__title-accent { color: var(--color-brand-lime); }

  .hero__subtitle {
    max-width: 32rem;
    margin: 1.25rem 0 1.75rem;
    color: rgb(255 255 255 / 0.78);
    font-size: clamp(1rem, 0.5vw + 0.85rem, 1.125rem);
    line-height: 1.55;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* ======================= SECTIONS ======================= */
  .section {
    padding: clamp(3rem, 6vw, 5rem) 0;
  }
  .section--light { background: var(--color-brand-white); }
  .section--navy  {
    background: var(--color-brand-navy);
    color: var(--color-brand-white);
  }

  .section__head {
    text-align: center;
    max-width: 48rem;
    margin: 0 auto 2.5rem;
  }
  .section__head p {
    margin-top: 0.85rem;
    color: var(--color-brand-gray);
    font-size: 1.05rem;
  }
  .section__head--on-dark h2 { color: var(--color-brand-white); }
  .section__head--on-dark p  { color: rgb(255 255 255 / 0.75); }

  .eyebrow {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-brand-gray);
    margin: 0 0 0.75rem;
  }
  .eyebrow--lime { color: var(--color-brand-lime); }
  .text-brand-white { color: var(--color-brand-white); }

  /* ======================= PRODUCT GRID ======================= */
  .product-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }
  .product-grid--2 {
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    max-width: 48rem;
    margin: 0 auto;
  }

  /* ======================= STEPS ======================= */
  .steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  }
  .step {
    position: relative;
    padding: 1.75rem 1.5rem;
    border: 1px solid rgb(255 255 255 / 0.12);
    border-radius: var(--radius-card);
    background: rgb(255 255 255 / 0.02);
    text-align: left;
  }
  .step__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    background: var(--color-brand-lime);
    color: var(--color-brand-navy);
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 900;
    margin-bottom: 1rem;
  }
  .step__title {
    color: var(--color-brand-white);
    font-size: 1.25rem;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
  }
  .step__desc {
    color: rgb(255 255 255 / 0.72);
    margin: 0;
    line-height: 1.55;
  }

  /* ======================= BANNER ======================= */
  .banner {
    display: grid;
    align-items: center;
    gap: 2rem;
    padding: 2.25rem;
    border-radius: var(--radius-card);
    background: linear-gradient(135deg, #f6ffce 0%, var(--color-brand-lime) 100%);
  }
  @media (min-width: 768px) {
    .banner { grid-template-columns: 1.2fr 1fr; padding: 3rem 3.5rem; }
  }
  .banner__eyebrow {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand-navy);
    opacity: 0.65;
    margin: 0 0 0.35rem;
  }
  .banner__title {
    font-size: clamp(1.5rem, 2vw + 1rem, 2.25rem);
    margin: 0 0 0.65rem;
    max-width: 24ch;
    letter-spacing: -0.01em;
  }
  .banner__sub {
    color: rgb(1 0 42 / 0.72);
    margin: 0;
    font-size: 1.02rem;
  }
  .banner__media {
    display: flex;
    justify-content: center;
  }
  .banner__media img {
    max-width: 340px;
    width: 100%;
    height: auto;
  }

  /* ======================= TESTIMONIALS ======================= */
  .testimonials .section__head h2 {
    font-size: clamp(1.75rem, 2vw + 1rem, 2.5rem);
  }
  .testimonial-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
  .testimonial {
    background: var(--color-brand-white);
    border: 1px solid rgb(1 0 42 / 0.08);
    border-radius: var(--radius-card);
    padding: 1.5rem;
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .testimonial__head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .testimonial__avatar {
    width: 40px;
    height: 40px;
    border-radius: 9999px;
    background: var(--color-brand-lime);
    color: var(--color-brand-navy);
    font-family: var(--font-display);
    font-weight: 900;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .testimonial__name {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 800;
    color: var(--color-brand-navy);
    font-size: 1rem;
  }
  .testimonial__when {
    margin: 0;
    color: var(--color-brand-gray);
    font-size: 0.82rem;
  }
  .testimonial__stars {
    display: inline-flex;
    gap: 0.125rem;
  }
  .testimonial__text {
    margin: 0;
    color: var(--color-brand-gray);
    line-height: 1.55;
  }

  /* ======================= FEATURES ======================= */
  .features-section { padding-top: 1rem; }
  .features {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
    padding: 2rem 1.5rem;
    border-top: 1px solid rgb(1 0 42 / 0.08);
    border-bottom: 1px solid rgb(1 0 42 / 0.08);
  }
  @media (min-width: 720px) {
    .features {
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      padding: 2.25rem 2rem;
    }
  }
  .feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.45rem;
    padding: 0 1rem;
    border-right: 1px solid rgb(1 0 42 / 0.08);
  }
  .feature:last-child { border-right: 0; }
  @media (max-width: 719px) {
    .feature { border-right: 0; border-bottom: 1px solid rgb(1 0 42 / 0.06); padding-bottom: 1.25rem; }
    .feature:last-child { border-bottom: 0; padding-bottom: 0; }
  }
  .feature :global(svg) { color: var(--color-brand-navy); }
  .feature h3 {
    font-size: 1.05rem;
    margin: 0.4rem 0 0;
    color: var(--color-brand-navy);
  }
  .feature p {
    margin: 0;
    color: var(--color-brand-gray);
    font-size: 0.95rem;
    max-width: 22ch;
  }

  /* ======================= PARCERIAS ======================= */
  .parcerias__grid {
    display: grid;
    gap: 2.5rem;
  }
  @media (min-width: 900px) {
    .parcerias__grid { grid-template-columns: 1.25fr 1fr; gap: 4rem; align-items: center; }
  }
  .parcerias__lead {
    color: rgb(255 255 255 / 0.8);
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 40rem;
    margin: 1rem 0 0;
  }
  .parcerias__bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .parcerias__bullets li {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    padding: 0.85rem 1rem;
    border-left: 3px solid var(--color-brand-lime);
    background: rgb(255 255 255 / 0.03);
    color: rgb(255 255 255 / 0.9);
    border-radius: 0 var(--radius-card) var(--radius-card) 0;
  }
</style>
