    min-height: clamp(480px, 75vh, 720px);
    display: flex;
    align-items: center;
  }
  @media (max-width: 899px) {
    /* Give the hero more height so there's room for the photo's barbell
       to breathe below the CTAs without cramping title + subtitle. The
       content stays vertically centered; padding below shifts it just
       above true center so the barbell is visible near the fold. */
    .hero { min-height: clamp(640px, 100vh, 820px); }
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
  }
  .hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: left center;
  }
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(90deg,
        rgb(1 0 42 / 0.35) 0%,
        rgb(1 0 42 / 0.35) 25%,
        rgb(1 0 42 / 0.85) 70%,
        rgb(1 0 42 / 0.95) 100%);
  }
  @media (max-width: 899px) {
    /* Anchor the focal point slightly above center so the bottom ~10%
       of the photo is cropped — barbell is the hero, we don't need the
       floor tiles. */
    .hero__bg img { object-position: center 40%; }
    .hero__scrim {
      background:
        linear-gradient(180deg,
          rgb(1 0 42 / 0.4) 0%,
          rgb(1 0 42 / 0.55) 45%,
          rgb(1 0 42 / 0.9) 100%);
    }
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-block: clamp(3rem, 6vw, 5rem);
  }
  @media (max-width: 899px) {
