---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Mail from "@lucide/astro/icons/mail";
import MapPin from "@lucide/astro/icons/map-pin";
import Clock from "@lucide/astro/icons/clock";
---

<BaseLayout
  title="Contato — PR Tracker"
  description="Fale com a PR Tracker por WhatsApp, e-mail ou pelo formulário. Atendimento Seg a Sex, 8h às 18h."
>
  <section class="contact">
    <div class="container-page contact__grid">
      <div class="contact__copy">
        <p class="contact__eyebrow">Fale com a gente</p>
        <h1>Estamos por aqui para qualquer dúvida.</h1>
        <p class="contact__lead">
          Pedidos, prazos, trocas, parceria com box ou creator — mande mensagem.
          Respondemos em dias úteis, 8h às 18h.
        </p>

        <ul class="contact__links">
          <li>
            <a href="https://wa.me/5551982061914" target="_blank" rel="noopener noreferrer" class="contact__link">
              <span class="contact__link-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.768.966-.941 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.85 12.85 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.695.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
              </span>
              <div>
                <div class="contact__link-label">WhatsApp</div>
                <div class="contact__link-value">(51) 98206-1914</div>
              </div>
            </a>
          </li>
          <li>
            <a href="mailto:contato@prtracker.com.br" class="contact__link">
              <span class="contact__link-icon"><Mail size={22} aria-hidden="true" /></span>
              <div>
                <div class="contact__link-label">E-mail</div>
                <div class="contact__link-value">contato@prtracker.com.br</div>
              </div>
            </a>
          </li>
          <li>
            <div class="contact__link contact__link--static">
              <span class="contact__link-icon"><Clock size={22} aria-hidden="true" /></span>
              <div>
                <div class="contact__link-label">Atendimento</div>
                <div class="contact__link-value">Seg a Sex · 8h às 18h</div>
              </div>
            </div>
          </li>
          <li>
            <div class="contact__link contact__link--static">
              <span class="contact__link-icon"><MapPin size={22} aria-hidden="true" /></span>
              <div>
                <div class="contact__link-label">Envio</div>
                <div class="contact__link-value">Para todo o Brasil com rastreio</div>
              </div>
            </div>
          </li>
        </ul>
      </div>

      <form class="contact__form" id="contactForm" action="https://formsubmit.co/contato@prtracker.com.br" method="POST">
        <input type="hidden" name="_subject" value="[Site] Novo contato" />
        <input type="hidden" name="_captcha" value="true" />
        <input type="hidden" name="_next" value="https://prtracker.com.br/contato?sent=true" />

        <h2 class="contact__form-title">Envie uma mensagem</h2>

        <div class="field">
          <label for="c-name">Nome</label>
          <input type="text" id="c-name" name="name" required minlength="2" autocomplete="name" />
        </div>
        <div class="field-row">
          <div class="field">
            <label for="c-email">E-mail</label>
            <input type="email" id="c-email" name="email" required autocomplete="email" />
          </div>
          <div class="field">
            <label for="c-phone">WhatsApp (opcional)</label>
            <input type="tel" id="c-phone" name="phone" autocomplete="tel" />
          </div>
        </div>
        <div class="field">
          <label for="c-subject">Assunto</label>
          <select id="c-subject" name="subject" required>
            <option value="">Selecione…</option>
            <option value="duvida">Dúvida sobre produto</option>
            <option value="pedido">Acompanhar pedido</option>
            <option value="troca">Troca ou devolução</option>
            <option value="parceria-box">Parceria com box</option>
            <option value="parceria-creator">Parceria com creator</option>
            <option value="outro">Outro</option>
          </select>
        </div>
        <div class="field">
          <label for="c-message">Mensagem</label>
          <textarea id="c-message" name="message" rows="5" required minlength="10"></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-lg w-full">Enviar mensagem</button>
        <p class="contact__form-note">Responderemos no e-mail informado em até 1 dia útil.</p>
      </form>
    </div>
  </section>

  <script>
    // Show success toast when ?sent=true in URL
    const params = new URLSearchParams(window.location.search);
    if (params.get("sent") === "true") {
      const form = document.querySelector("#contactForm");
      if (form) {
        const banner = document.createElement("div");
        banner.className = "contact__sent";
        banner.setAttribute("role", "status");
        banner.textContent = "Mensagem enviada! Responderemos em até 1 dia útil.";
        form.parentElement?.insertBefore(banner, form);
      }
    }
  </script>
</BaseLayout>

<style>
  .contact { padding: 3rem 0 5rem; }
  .contact__grid {
    display: grid;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 900px) {
    .contact__grid { grid-template-columns: 1fr 1.1fr; gap: 4rem; }
  }

  .contact__eyebrow {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-brand-lime);
    filter: brightness(0.55);
    margin: 0 0 0.5rem;
  }
  .contact__copy h1 { margin: 0 0 1rem; max-width: 16ch; }
  .contact__lead {
    color: var(--color-brand-gray);
    font-size: 1.125rem;
    line-height: 1.6;
    margin: 0 0 2rem;
    max-width: 32rem;
  }

  .contact__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .contact__link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid rgb(1 0 42 / 0.08);
    border-radius: 0.875rem;
    background: var(--color-brand-white);
    text-decoration: none;
    color: inherit;
    transition: box-shadow 150ms ease, border-color 150ms ease;
  }
  .contact__link:hover {
    border-color: var(--color-brand-navy);
    box-shadow: 0 4px 12px rgb(1 0 42 / 0.06);
  }
  .contact__link--static { cursor: default; }
  .contact__link--static:hover { border-color: rgb(1 0 42 / 0.08); box-shadow: none; }
  .contact__link-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 9999px;
    background: rgb(216 255 44 / 0.18);
    color: var(--color-brand-navy);
    flex-shrink: 0;
  }
  .contact__link-label {
    font-size: 0.78rem;
    color: var(--color-brand-gray);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .contact__link-value {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-brand-navy);
    font-size: 1rem;
  }

  .contact__form {
    background: var(--color-brand-white);
    border: 1px solid rgb(1 0 42 / 0.08);
    border-radius: var(--radius-card);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .contact__form-title {
    font-size: 1.5rem;
    margin: 0 0 0.5rem;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .field-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .field-row .field { flex: 1 1 180px; }
  .field label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-brand-navy);
  }
  .field input, .field select, .field textarea {
    padding: 0.75rem 0.875rem;
    border: 1.5px solid rgb(1 0 42 / 0.12);
    border-radius: 0.5rem;
    font-family: var(--font-body);
    font-size: 1rem;
    background: var(--color-brand-white);
    color: var(--color-brand-navy);
    transition: border-color 150ms ease;
  }
  .field textarea { resize: vertical; font-family: var(--font-body); }
  .field input:focus-visible,
  .field select:focus-visible,
  .field textarea:focus-visible {
    outline: 2px solid var(--color-brand-lime);
    outline-offset: 1px;
    border-color: var(--color-brand-navy);
  }

  .contact__form-note {
    color: var(--color-brand-gray);
    font-size: 0.85rem;
    margin: 0;
    text-align: center;
  }
  .w-full { width: 100%; }

  .contact__sent {
    background: #dcfce7;
    border: 1px solid #86efac;
    color: #166534;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    margin-bottom: 1rem;
    font-weight: 600;
  }
</style>
