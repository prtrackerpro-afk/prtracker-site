---
import BaseLayout from "~/layouts/BaseLayout.astro";
import ArrowRight from "@lucide/astro/icons/arrow-right";
---

<BaseLayout
  title="Carrinho — PR Tracker"
  description="Revise os itens do seu carrinho, ajuste quantidades e finalize sua compra."
  noindex
>
  <section class="cart-page">
    <div class="container-page">
      <header class="cart-page__header">
        <h1>Seu Carrinho</h1>
      </header>

      <div class="cart-page__layout">
        <div class="cart-page__items" data-cart-items-wrapper>
          <div class="cart-page__empty" data-cart-empty>
            <p class="cart-page__empty-title">Seu carrinho está vazio.</p>
            <p class="cart-page__empty-sub">Escolha um troféu para começar.</p>
            <a href="/#produtos" class="btn btn-primary mt-6">
              Ver produtos
              <ArrowRight size={18} aria-hidden="true" />
            </a>
          </div>
          <ul class="cart-page__list" data-cart-items hidden></ul>
        </div>

        <aside class="cart-page__summary" data-cart-summary hidden>
          <h2 class="cart-page__summary-title">Resumo</h2>
          <dl class="cart-page__summary-dl">
            <div class="cart-page__summary-row">
              <dt>Subtotal</dt>
              <dd data-cart-subtotal>R$ 0,00</dd>
            </div>
            <div class="cart-page__summary-row cart-page__summary-row--pix">
              <dt>
                <span class="pix-badge">Pix</span>
                <span class="text-brand-gray text-sm">5 % OFF no total</span>
              </dt>
              <dd data-cart-pix-total class="cart-page__summary-pix">R$ 0,00</dd>
            </div>
            <div class="cart-page__summary-row">
              <dt>Ou no cartão</dt>
              <dd data-cart-installment>6× de R$ 0,00 sem juros</dd>
            </div>
          </dl>
          <a href="/checkout" class="btn btn-primary btn-lg w-full mt-6">
            Finalizar compra
            <ArrowRight size={18} aria-hidden="true" />
          </a>
          <a href="/#produtos" class="btn btn-outline w-full mt-3">Continuar comprando</a>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .cart-page { padding: 3rem 0 5rem; }
  .cart-page__header h1 { margin: 0 0 2.5rem; }

  .cart-page__layout {
    display: grid;
    gap: 2rem;
  }
  @media (min-width: 900px) {
    .cart-page__layout { grid-template-columns: 1.5fr 1fr; gap: 3rem; align-items: start; }
  }

  .cart-page__empty {
    padding: 3rem 1rem;
    text-align: center;
    border: 1px dashed rgb(1 0 42 / 0.15);
    border-radius: var(--radius-card);
    background: #fafafc;
  }
  .cart-page__empty-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-brand-navy);
  }
  .cart-page__empty-sub {
    color: var(--color-brand-gray);
    margin-top: 0.5rem;
  }

  .cart-page__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cart-line {
    display: grid;
    grid-template-columns: 96px 1fr auto;
    gap: 1.25rem;
    padding: 1.25rem;
    background: var(--color-brand-white);
    border: 1px solid rgb(1 0 42 / 0.08);
    border-radius: var(--radius-card);
    align-items: center;
  }
  .cart-line__img {
    width: 96px;
    height: 96px;
    object-fit: contain;
    background: #f7f7fb;
    border-radius: 0.75rem;
  }
  .cart-line__meta { display: flex; flex-direction: column; gap: 0.4rem; min-width: 0; }
  .cart-line__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.3;
    color: var(--color-brand-navy);
    margin: 0;
  }
  .cart-line__config {
    font-size: 0.85rem;
    color: var(--color-brand-gray);
  }
  .cart-line__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.25rem;
  }
  .cart-line__qty {
    display: inline-flex;
    align-items: center;
    gap: 0;
    border: 1px solid rgb(1 0 42 / 0.12);
    border-radius: 9999px;
    overflow: hidden;
  }
  .cart-line__qty button {
    width: 32px;
    height: 32px;
    background: transparent;
    border: none;
    color: var(--color-brand-navy);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .cart-line__qty button:hover { background: rgb(1 0 42 / 0.05); }
  .cart-line__qty-value {
    min-width: 1.75rem;
    text-align: center;
    font-weight: 600;
  }

  .cart-line__side {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
  }
  .cart-line__price {
    font-family: var(--font-display);
    font-weight: 800;
    color: var(--color-brand-navy);
    font-size: 1.05rem;
  }
  .cart-line__remove {
    background: transparent;
    border: none;
    color: var(--color-brand-gray);
    cursor: pointer;
    font-size: 0.85rem;
    padding: 0.3rem 0.5rem;
    border-radius: 0.5rem;
    transition: color 150ms ease, background-color 150ms ease;
  }
  .cart-line__remove:hover {
    color: #b91c1c;
    background: rgb(185 28 28 / 0.08);
  }

  .cart-page__summary {
    padding: 1.75rem;
    background: var(--color-brand-white);
    border: 1px solid rgb(1 0 42 / 0.08);
    border-radius: var(--radius-card);
    position: sticky;
    top: 6rem;
  }
  .cart-page__summary-title {
    font-size: 1.25rem;
    margin: 0 0 1.25rem;
  }
  .cart-page__summary-dl { margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.65rem; }
  .cart-page__summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .cart-page__summary-row dt { margin: 0; color: var(--color-brand-gray); }
  .cart-page__summary-row dd { margin: 0; font-weight: 700; color: var(--color-brand-navy); }
  .cart-page__summary-pix {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: #16a34a;
  }

  .pix-badge {
    display: inline-block;
    background: var(--color-brand-lime);
    color: var(--color-brand-navy);
    padding: 0.2rem 0.65rem;
    border-radius: 9999px;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .text-sm { font-size: 0.85rem; }
  .w-full { width: 100%; }
  .mt-3 { margin-top: 0.75rem; }
  .mt-6 { margin-top: 1.5rem; }
</style>

<script>
  import { cart } from "~/scripts/cart";
  import type { CartSnapshot } from "~/lib/cart-types";
  import { formatBRL } from "~/lib/format";

  const wrapper = document.querySelector<HTMLElement>("[data-cart-items-wrapper]")!;
  const empty = wrapper.querySelector<HTMLElement>("[data-cart-empty]")!;
  const list = wrapper.querySelector<HTMLUListElement>("[data-cart-items]")!;
  const summary = document.querySelector<HTMLElement>("[data-cart-summary]")!;
  const subtotalEl = summary.querySelector<HTMLElement>("[data-cart-subtotal]")!;
  const pixEl = summary.querySelector<HTMLElement>("[data-cart-pix-total]")!;
  const installmentEl = summary.querySelector<HTMLElement>("[data-cart-installment]")!;

  function escapeHtml(str: string): string {
    return str
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function configLine(item: CartSnapshot["items"][number]): string {
    const parts: string[] = [];
    if (item.plates?.length) {
      parts.push(
        item.plates
          .filter((p) => p.pairs > 0)
          .map((p) => `${p.pairs * 2}× ${p.plateId.replace("_", ".")} kg`)
          .join(" · "),
      );
    }
    if (item.exercise) parts.push(item.exercise);
    if (item.size) parts.push(`Tam. ${item.size}`);
    return parts.filter(Boolean).join(" · ");
  }

  function render(snap: CartSnapshot) {
    if (snap.items.length === 0) {
      empty.hidden = false;
      list.hidden = true;
      summary.hidden = true;
      return;
    }
    empty.hidden = true;
    list.hidden = false;
    summary.hidden = false;

    list.innerHTML = snap.items
      .map((item) => {
        const cfg = configLine(item);
        return `
          <li class="cart-line" data-id="${escapeHtml(item.id)}">
            <img src="${escapeHtml(item.image)}" alt="" class="cart-line__img" width="96" height="96" loading="lazy" />
            <div class="cart-line__meta">
              <p class="cart-line__title">${escapeHtml(item.title)}</p>
              ${cfg ? `<p class="cart-line__config">${escapeHtml(cfg)}</p>` : ""}
              <div class="cart-line__row">
                <div class="cart-line__qty" role="group" aria-label="Quantidade">
                  <button type="button" aria-label="Diminuir" data-qty-down>
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  </button>
                  <span class="cart-line__qty-value">${item.quantity}</span>
                  <button type="button" aria-label="Aumentar" data-qty-up>
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  </button>
                </div>
              </div>
            </div>
            <div class="cart-line__side">
              <span class="cart-line__price">${formatBRL(item.unitPriceCents * item.quantity)}</span>
              <button type="button" class="cart-line__remove" data-remove>Remover</button>
            </div>
          </li>
        `;
      })
      .join("");

    subtotalEl.textContent = formatBRL(snap.subtotalCents);
    pixEl.textContent = formatBRL(snap.pixTotalCents);
    installmentEl.textContent = `6× de ${formatBRL(Math.round(snap.subtotalCents / 6))} sem juros`;
  }

  render(cart.snapshot());

  document.addEventListener("cart:change", (ev) => {
    render((ev as CustomEvent<CartSnapshot>).detail ?? cart.snapshot());
  });

  list.addEventListener("click", (ev) => {
    const target = ev.target as HTMLElement;
    const li = target.closest<HTMLLIElement>(".cart-line");
    if (!li) return;
    const id = li.dataset.id!;
    if (target.closest("[data-qty-down]")) {
      const c = cart.snapshot().items.find((i) => i.id === id);
      if (c) cart.updateQuantity(id, c.quantity - 1);
    } else if (target.closest("[data-qty-up]")) {
      const c = cart.snapshot().items.find((i) => i.id === id);
      if (c) cart.updateQuantity(id, c.quantity + 1);
    } else if (target.closest("[data-remove]")) {
      cart.remove(id);
    }
  });
</script>
