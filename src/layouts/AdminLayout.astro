---
import "../styles/global.css";

interface Props {
  title: string;
  active?: "overview" | "meta" | "ga4" | "sales" | "alerts" | "settings";
  user?: { email: string };
}

const { title, active = "overview", user } = Astro.props;

const navItems = [
  { id: "overview", label: "Overview", href: "/admin", icon: "📊" },
  { id: "meta", label: "Meta Ads", href: "/admin/meta", icon: "📈" },
  { id: "ga4", label: "GA4 / Site", href: "/admin/ga4", icon: "🌐" },
  { id: "sales", label: "Vendas", href: "/admin/sales", icon: "💰" },
  { id: "alerts", label: "Alertas", href: "/admin/alerts", icon: "🚨" },
] as const;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title} · PR Tracker Admin</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-navy-900 text-white font-body antialiased">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="hidden md:flex w-64 flex-col border-r border-navy-700 bg-navy-800/50 p-6">
        <div class="mb-8">
          <div class="font-display text-2xl tracking-tight text-brand-lime">PR Tracker</div>
          <div class="text-xs uppercase tracking-widest text-navy-300 mt-1">Admin Console</div>
        </div>
        <nav class="flex-1 space-y-1">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition",
                  active === item.id
                    ? "bg-brand-lime text-navy-900 font-semibold"
                    : "text-navy-200 hover:bg-navy-700/50 hover:text-white",
                ]}
              >
                <span class="text-lg">{item.icon}</span>
                <span>{item.label}</span>
              </a>
            ))
          }
        </nav>
        {
          user && (
            <div class="mt-auto border-t border-navy-700 pt-4">
              <div class="text-xs text-navy-300 mb-2">Logado como</div>
              <div class="text-sm truncate" title={user.email}>
                {user.email}
              </div>
              <button
                id="admin-logout"
                class="mt-3 w-full text-xs text-navy-300 hover:text-white transition text-left"
              >
                ↗ Sair
              </button>
            </div>
          )
        }
      </aside>

      <!-- Main content -->
      <main class="flex-1 flex flex-col">
        <header class="md:hidden flex items-center justify-between border-b border-navy-700 px-4 py-3 bg-navy-800/50">
          <div class="font-display text-lg text-brand-lime">PR Tracker Admin</div>
          <details class="relative">
            <summary class="cursor-pointer text-navy-200">☰</summary>
            <nav
              class="absolute right-0 top-full mt-2 w-56 rounded-lg border border-navy-700 bg-navy-800 p-2 shadow-xl z-10"
            >
              {
                navItems.map((item) => (
                  <a
                    href={item.href}
                    class="block rounded px-3 py-2 text-sm text-navy-200 hover:bg-navy-700"
                  >
                    {item.icon} {item.label}
                  </a>
                ))
              }
            </nav>
          </details>
        </header>

        <div class="flex-1 p-4 md:p-8 max-w-[1600px] w-full mx-auto">
          <slot />
        </div>
      </main>
    </div>

    <script>
      const logoutBtn = document.getElementById("admin-logout");
      if (logoutBtn) {
        logoutBtn.addEventListener("click", async () => {
          try {
            await fetch("/api/admin/logout", { method: "POST" });
          } catch {}
          window.location.href = "/admin/login";
        });
      }
    </script>
  </body>
</html>
